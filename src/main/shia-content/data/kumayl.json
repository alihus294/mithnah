    {
      "kind": "text",
      "ar": "وَكَمْ مِنْ عِثَارٍ وَقَیْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَكَمْ مِنْ مَكْرُوْہٍ دَفَعْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَكَمْ مِنْ ثَنَاءٍ جَمِیْلٍ لَسْتُ ٲَھْلًا لَہٗ نَشَرْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ عَظُمَ بَلَائِیْ"
    },
    {
      "kind": "text",
      "ar": "وَٲَفْرَطَ بِیْ سُوْءُ حَالِیْ"
    },
    {
      "kind": "text",
      "ar": "وَقَصُرَتْ بِیْ ٲَعْمَالِیْ"
    },
    {
      "kind": "text",
      "ar": "وَقَعَدَتْ بِیْ ٲَغْلَالِیْ"
    },
    {
      "kind": "text",
      "ar": "وَحَبَسَنِیْ عَنْ نَفْعِیْ بُعْدُ اٰمَالِیْ"
    },
    {
      "kind": "text",
      "ar": "وَخَدَعَتْنِی الدُّنْیَا بِغُرُوْرِہَا"
