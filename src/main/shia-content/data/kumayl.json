{
  "id": "kumayl",
  "title": "دعاء كُمَيْل",
  "subtitle": "علّمه أمير المؤمنين عليه السلام كُمَيل بن زياد",
  "source": "مفاتيح الجنان",
  "fiqh": "shia",
  "slides": [
    {
      "kind": "title",
      "ar": "دعاء كُمَيْل",
      "subtitle": "علّمه أمير المؤمنين ع كُمَيل بن زياد"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنِّیْ ٲَسْٲَلُكَ بِرَحْمَتِكَ الَّتِیْ وَسِعَتْ كُلَّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "وَبِقُوَّتِكَ الَّتِیْ قَھَرْتَ بِہَا كُلَّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "وَخَضَعَ لَہَا كُلُّ شَیْءٍ، وَذَلَّ لَہَا كُلُّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "وَبِجَبَرُوْتِكَ الَّتِیْ غَلَبْتَ بِہَا كُلَّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "وَبِعِزَّتِكَ الَّتِیْ لَا یَقُوْمُ لَہَا شَیْءٌ"
    },
    {
      "kind": "text",
      "ar": "وَبِعَظَمَتِكَ الَّتِیْ مَلَأَتْ كُلَّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "وَبِسُلْطَانِكَ الَّذِیْ عَلَا كُلَّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "وَبِوَجْھِكَ الْبَاقِیْ بَعْدَ فَنَاءِ كُلِّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "وَبِٲَسْمَائِكَ الَّتِیْ مَلَأَتْ ٲَرْكَانَ كُلِّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "وَبِعِلْمِكَ الَّذِیْ ٲَحَاطَ بِكُلِّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "وَبِنُوْرِ وَجْھِكَ الَّذِیْ ٲَضَاءَ لَہٗ كُلُّ شَیْءٍ"
    },
    {
      "kind": "text",
      "ar": "یَا نُوْرُ یَا قُدُّوْسُ"
    },
    {
      "kind": "text",
      "ar": "یَا ٲَوَّلَ الْاَوَّلِیْنَ ، وَیَا اٰخِرَ الْاٰخِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اغْفِرْلِیَ الذُّنُوْبَ الَّتِیْ تَھْتِكُ الْعِصَمَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اغْفِرْلِیَ الذُّنُوْبَ الَّتِیْ تُنْزِلُ النِّقَمَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اغْفِرْلِیَ الذُّنُوْبَ الَّتِیْ تُغَیِّرُ النِّعَمَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اغْفِرْلِیَ الذُّنُوْبَ الَّتِیْ تَحْبِسُ الدُّعَاءَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اغْفِرْلِیَ الذُّنُوْبَ الَّتِیْ تُنْزِلُ الْبَلَاءَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اغْفِرْلِیْ كُلَّ ذَنْبٍ ٲَذْنَبْتُۃٗ"
    },
    {
      "kind": "text",
      "ar": "وَكُلَّ خَطِیْئَۃٍ ٲَخْطَٲْتُہَا"
