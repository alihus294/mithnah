    {
      "kind": "text",
      "ar": "ٲَتُرَاكَ مُعَذِّبِیْ بِنَارِكَ بَعْدَ تَوْحِیْدِكَ"
    },
    {
      "kind": "text",
      "ar": "وَبَعْدَ مَا انْطَوٰی عَلَیْہِ قَلْبِیْ مِنْ مَعْرِفَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَلَھِجَ بِہٖ لِسَانِیْ مِنْ ذِكْرِكَ"
    },
    {
      "kind": "text",
      "ar": "وَاعْتَقَدَھٗ ضَمِیْرِیْ مِنْ حُبِّكَ"
    },
    {
      "kind": "text",
      "ar": "وَبَعْدَ صِدْقِ اعْتِرَافِیْ وَدُعَائِیْ خَاضِعًا لِرُبُوْبِیَّتِكَ"
    },
    {
      "kind": "text",
      "ar": "ھَیْھَاتَ ٲَنْتَ ٲَكْرَمُ مِنْ ٲَنْ تُضَیِّعَ مَنْ رَبَّیْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "ٲَوْ تُبَعِّدَ مَنْ ٲَدْنَیْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "ٲَوْ تُشَرِّدَ مَنْ اٰوَیْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "ٲَوْ تُسَلِّمَ اِلَی الْبَلَاءِ مَنْ كَفَیْتَہٗ وَرَحِمْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَلَیْتَ شِعْرِیْ یَا سَیِّدِیْ وَاِلٰھِیْ وَمَوْلَایَ"
    },
    {
      "kind": "text",
      "ar": "ٲَتُسَلِّطُ النَّارَ عَلٰی وُجُوْہٍ خَرَّتْ لِعَظَمَتِكَ سَاجِدَۃً"
