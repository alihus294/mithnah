    },
    {
      "kind": "text",
      "ar": "یَا خَبِیْرًا بِفَقْرِیْ وَفَاقَتِیْ"
    },
    {
      "kind": "text",
      "ar": "یَا رَبِّ یَا رَبِّ یَا رَبِّ"
    },
    {
      "kind": "text",
      "ar": "ٲَسْٲَلُكَ بِحَقِّكَ وَقُدْسِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَعْظَمِ صِفَاتِكَ وَٲَسْمَائِكَ"
    },
    {
      "kind": "text",
      "ar": "ٲَنْ تَجْعَلَ ٲَوْقَاتِیْ فِی اللَّیْلِ وَالنَّہَارِ بِذِكْرِكَ مَعْمُوْرَۃً"
    },
    {
      "kind": "text",
      "ar": "وَبِخِدْمَتِكَ مَوْصُوْلَۃً"
    },
    {
      "kind": "text",
      "ar": "وَٲَعْمَالِیْ عِنْدَكَ مَقْبُوْلَۃً"
    },
    {
      "kind": "text",
      "ar": "حَتّٰی تَكُوْنَ ٲَعْمَالِیْ وَٲَوْرَادِیْ كُلُّہَا وِرْدًا وَاحِدًا"
    },
    {
      "kind": "text",
      "ar": "وَحَالِیْ فِیْ خِدْمَتِكَ سَرْمَدًا"
    },
    {
      "kind": "text",
      "ar": "یَا سَیِّدِیْ یَا مَنْ عَلَیْہِ مُعَوَّلِیْ"
    },
    {
      "kind": "text",
      "ar": "یَا مَنْ اِلَیْہِ شَكَوْتُ ٲَحْوَالِیْ"
    },
    {
      "kind": "text",
      "ar": "یَا رَبِّ یَا رَبِّ یَا رَبِّ"
    },
    {
      "kind": "text",
      "ar": "قَوِّ عَلٰی خِدْمَتِكَ جَوَارِحِیْ"
    },
    {
      "kind": "text",
      "ar": "وَاشْدُدْ عَلَی الْعَزِیْمَۃِ جَوَانِحِیْ"
    },
    {
      "kind": "text",
      "ar": "وَھَبْ لِیَ الْجِدَّ فِیْ خَشْیَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَالدَّوَامَ فِی الْاِتِّصَالِ بِخِدْمَتِكَ"
    },
    {
      "kind": "text",
      "ar": "حَتّٰی ٲَسْرَحَ اِلَیْكَ فِیْ مَیَادِیْنِ السَّابِقِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَٲُسْرِعَ اِلَیْكَ فِی الْبَارِزِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَشْتَاقَ اِلٰی قُرْبِكَ فِی الْمُشْتَاقِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَدْنُوَ مِنْكَ دُنُوَّ الْمُخْلِصِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَخَافَكَ مَخَافَۃَ الْمُوْقِنِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَجْتَمِعَ فِیْ جِوَارِكَ مَعَ الْمُؤْمِنِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ وَمَنْ ٲَرَادَنِیْ بِسُوْءٍ فَٲَرِدْھُ"
    },
    {
      "kind": "text",
      "ar": "وَمَنْ كَادَنِیْ فَكِدْھُ"
    },
    {
      "kind": "text",
      "ar": "وَاجْعَلْنِیْ مِنْ ٲَحْسَنِ عَبِیْدِكَ نَصِیْبًا عِنْدَكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَقْرَبِھِمْ مَنْزِلَۃً مِنْكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَخَصِّھِمْ زُلْفَۃً لَدَیْكَ"
    },
    {
      "kind": "text",
      "ar": "فَاِنَّہٗ لَا یُنَالُ ذٰلِكَ اِلَّا بِفَضْلِكَ"
    },
    {
      "kind": "text",
      "ar": "وَجُدْ لِیْ بِجُوْدِكَ"
    },
    {
      "kind": "text",
      "ar": "وَاعْطِفْ عَلَیَّ بِمَجْدِكَ"
    },
    {
      "kind": "text",
      "ar": "وَاحْفَظْنِیْ بِرَحْمَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَاجْعَلْ لِسَانِیْ بِذِكْرِكَ لَھِجًا"
    },
    {
      "kind": "text",
      "ar": "وَقَلْبِیْ بِحُبِّكَ مُتَیَّمًا"
    },
    {
      "kind": "text",
      "ar": "وَمُنَّ عَلَیَّ بِحُسْنِ اِجَابَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَقِلْنِیْ عَثْرَتِیْ وَاغْفِرْ زَلَّتِیْ"
    },
    {
      "kind": "text",
      "ar": "فَاِنَّكَ قَضَیْتَ عَلٰی عِبَادِكَ بِعِبَادَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَمَرْتَھُمْ بِدُعَائِكَ"
    },
    {
      "kind": "text",
      "ar": "وَضَمِنْتَ لَھُمُ الْاِجَابَۃَ"
    },
    {
      "kind": "text",
      "ar": "فَاِلَیْكَ یَارَبِّ نَصَبْتُ وَجْھِیْ"
    },
    {
      "kind": "text",
      "ar": "وَاِلَیْكَ یَا رَبِّ مَدَدْتُ یَدِیْ"
    },
    {
      "kind": "text",
      "ar": "فَبِعِزَّتِكَ اسْتَجِبْ لِیْ دُعَائِیْ، وَبَلِّغْنِیْ مُنَایَ"
    },
    {
      "kind": "text",
      "ar": "وَلَا تَقْطَعْ مِنْ فَضْلِكَ رَجَائِیْ"
    },
    {
      "kind": "text",
      "ar": "وَاكْفِنِیْ شَرَّ الْجِنِّ وَالْاِنْسِ مِنْ ٲَعْدَائِیْ"
    },
    {
      "kind": "text",
      "ar": "یَا سَرِیْعَ الرِّضَا"
    },
    {
      "kind": "text",
      "ar": "اغْفِرْ لِمَنْ لَا یَمْلِكُ اِلَّا الدُّعَاءَ"
    },
    {
      "kind": "text",
      "ar": "فَاِنَّكَ فَعَّالٌ لِمَا تَشَاءُ"
    },
    {
      "kind": "text",
      "ar": "یَا مَنِ اسْمُہٗ دَوَاءٌ"
    },
    {
      "kind": "text",
      "ar": "وَذِكْرُھٗ شِفَاءٌ، وَطَاعَتُہٗ غِنًى"
    },
    {
      "kind": "text",
      "ar": "اِرْحَمْ مَنْ رَٲْسُ مَالِہِ الرَّجَاءُ"
    },
    {
      "kind": "text",
      "ar": "وَسِلَاحُہُ الْبُكَاءُ"
    },
    {
      "kind": "text",
      "ar": "یَا سَابِغَ النِّعَمِ، یَا دَافِعَ النِّقَمِ"
    },
    {
      "kind": "text",
      "ar": "یَا نُوْرَ الْمُسْتَوْحِشِیْنَ فِی الظُّلَمِ"
    },
    {
      "kind": "text",
      "ar": "یَا عَالِمًا لَا یُعَلَّمُ"
    },
    {
      "kind": "text",
      "ar": "صَلِّ عَلٰی مُحَمَّدٍ وَاٰلِ مُحَمَّدٍ"
    },
    {
      "kind": "text",
      "ar": "وَافْعَلْ بِیْ مَا ٲَنْتَ ٲَھْلُہٗ"
    },
    {
      "kind": "text",
      "ar": "وَصَلَّی ﷲُ عَلٰی رَسُوْلِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَالْاَئِمَّۃِ الْمَیَامِیْنَ مِنْ اٰلِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَسَلَّمَ تَسْلِیْمًا كَثِیْرًا"
    }
  ]
}