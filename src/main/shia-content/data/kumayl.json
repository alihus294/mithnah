    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ وَٲَسْٲَلُكَ سُؤَالَ مَنِ اشْتَدَّتْ فَاقَتُہٗ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْزَلَ بِكَ عِنْدَ الشَّدَائِدِ حَاجَتَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَعَظُمَ فِیْمَا عِنْدَكَ رَغْبَتُہٗ"
