    {
      "kind": "text",
      "ar": "وَٲَسْٲَلُكَ بِجُوْدِكَ ٲَنْ تُدْنِیَنِیْ مِنْ قُرْبِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْ تُوْزِعَنِیْ شُكْرَكَ وَٲَنْ تُلْھِمَنِیْ ذِكْرَكَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنِّیْ ٲَسْٲَلُكَ سُؤَالَ خَاضِعٍ مُتَذَلِّلٍ خَاشِعٍ"
    },
    {
      "kind": "text",
      "ar": "ٲَنْ تُسَامِحَنِیْ وَتَرْحَمَنِیْ"
    },
    {
      "kind": "text",
      "ar": "وَتَجْعَلَنِیْ بِقِسْمِكَ رَاضِیًا قَانِعًا"
    },
    {
      "kind": "text",
      "ar": "وَفِیْ جَمِیْعِ الْاَحْوَالِ مُتَوَاضِعًا"
