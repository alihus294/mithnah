      "kind": "text",
      "ar": "وَلَا حُجَّۃَ لِیْ فِیْمَا جَرٰی عَلَیَّ فِیْہِ قَضَاؤُكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَلْزَمَنِیْ حُكْمُكَ وَبَلَاؤُكَ"
    },
    {
      "kind": "text",
      "ar": "وَقَدْ ٲَتَیْتُكَ یَا اِلٰھِیْ بَعْدَ تَقْصِیْرِیْ وَاِسْرَافِیْ عَلٰی نَفْسِیْ"
    },
    {
      "kind": "text",
      "ar": "مُعْتَذِرًا نَادِمًا مُنْكَسِرًا مُسْتَقِیْلًا"
    },
    {
      "kind": "text",
      "ar": "مُسْتَغْفِرًا مُنِیْبًا مُقِرًّا مُذْعِنًا مُعْتَرِفًا"
    },
    {
      "kind": "text",
      "ar": "لَا ٲَجِدُ مَفَرًّا مِمَّا كَانَ مِنِّیْ"
