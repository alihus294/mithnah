    {
      "kind": "text",
      "ar": "وَغَلَبَ قَھْرُكَ وَجَرَتْ قُدْرَتُكَ"
    },
    {
      "kind": "text",
      "ar": "وَلَا یُمْكِنُ الْفِرَارُ مِنْ حُكُوْمَتِكَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ لَا ٲَجِدُ لِذُنُوْبِیْ غَافِرًا، وَلَا لِقَبَائِحِیْ سَاتِرًا"
    },
    {
      "kind": "text",
      "ar": "وَلَا لِشَیْءٍ مِنْ عَمَلِیَ الْقَبِیْحِ بِالْحَسَنِ مُبَدِّلًا غَیْرَكَ"
    },
    {
      "kind": "text",
      "ar": "لَا اِلٰہَ اِلَّا ٲَنْتَ سُبْحَانَكَ وَبِحَمْدِكَ"
    },
    {
      "kind": "text",
      "ar": "ظَلَمْتُ نَفْسِیْ، وَتَجَرَّٲْتُ بِجَھْلِیْ"
