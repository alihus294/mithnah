    {
      "kind": "text",
      "ar": "وَلَا مَفْزَعًا ٲَتَوَجَّہُ اِلَیْہِ فِیْ ٲَمْرِیْ"
    },
    {
      "kind": "text",
      "ar": "غَیْرَ قَبُوْلِكَ عُذْرِیْ"
    },
    {
      "kind": "text",
      "ar": "وَاِدْخَالِكَ اِیَّایَ فِیْ سَعَۃٍ مِنْ رَحْمَتِكَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ فَاقْبَلْ عُذْرِیْ"
    },
    {
      "kind": "text",
      "ar": "وَارْحَمْ شِدَّۃَ ضُرِّیْ"
    },
    {
      "kind": "text",
      "ar": "وَفُكَّنِیْ مِنْ شَدِّ وَثَاقِیْ"
    },
    {
      "kind": "text",
      "ar": "یَا رَبِّ ارْحَمْ ضَعْفَ بَدَنِیْ"
    },
    {
      "kind": "text",
      "ar": "وَرِقَّۃَ جِلْدِیْ وَدِقَّۃَ عَظْمِیْ"
    },
    {
      "kind": "text",
      "ar": "یَا مَنْ بَدَٲَ خَلْقِیْ وَذِكْرِیْ وَتَرْبِیَتِیْ وَبِرِّیْ وَتَغْذِیَتِیْ"
    },
    {
      "kind": "text",
      "ar": "ھَبْنِیْ لِابْتِدَاءِ كَرَمِكَ وَسَالِفِ بِرِّكَ بِیْ"
    },
    {
      "kind": "text",
      "ar": "یَا اِلٰھِیْ وَسَیِّدِیْ وَرَبِّیْ"
