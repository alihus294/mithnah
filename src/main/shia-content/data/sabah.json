{
  "id": "sabah",
  "title": "دعاء الصَّباح",
  "subtitle": "لأمير المؤمنين علي عليه السلام",
  "source": "مفاتيح الجنان",
  "fiqh": "shia",
  "slides": [
    {
      "kind": "title",
      "ar": "دعاء الصَّباح",
      "subtitle": "لأمير المؤمنين علي ع"
    },
    {
      "kind": "text",
      "ar": "بِسْمِ ﷲِ الرَّحْمٰنِ الرَّحِیْمِ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ یَا مَنْ دَلَعَ لِسَانَ الصَّبَاحِ بِنُطْقِ تَبَلُّجِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَسَرَّحَ قِطَعَ اللَّیْلِ الْمُظْلِمِ بِغَیَاھِبِ تَلَجْلُجِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَٲَتْقَنَ صُنْعَ الْفَلَكِ الدَّوَّارِ فِیْ مَقَادِیْرِ تَبَرُّجِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَشَعْشَعَ ضِیَاءَ الشَّمْسِ بِنُوْرِ تَٲَجُّجِہٖ"
    },
    {
      "kind": "text",
      "ar": "یَا مَنْ دَلَّ عَلٰی ذَاتِہٖ بِذَاتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَتَنَزَّہَ عَنْ مُجَانَسَۃِ مَخْلُوْقَاتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَجَلَّ عَنْ مُلَائَمَۃِ كَیْفِیَّاتِہٖ"
    },
    {
      "kind": "text",
      "ar": "یَا مَنْ قَرُبَ مِنْ خَطَرَاتِ الظُّنُوْنِ"
    },
    {
      "kind": "text",
      "ar": "وَبَعُدَ عَنْ لَحَظَاتِ الْعُیُوْنِ"
    },
    {
      "kind": "text",
      "ar": "وَعَلِمَ بِمَا كَانَ قَبْلَ ٲَنْ یَكُوْنَ"
    },
    {
      "kind": "text",
      "ar": "یَا مَنْ ٲَرْقَدَنِیْ فِیْ مِھَادِ ٲَمْنِہٖ وَٲَمَانِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَٲَیْقَظَنِیْ اِلٰی مَا مَنَحَنِیْ بِہٖ مِنْ مِنَنِہٖ وَاِحْسَانِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَكَفَّ ٲَكُفَّ السُّوْءِ عَنِّیْ بِیَدِھٖ وَسُلْطَانِہٖ"
    },
    {
      "kind": "text",
      "ar": "صَلِّ اللّٰھُمَّ عَلَی الدَّلِیْلِ اِلَیْكَ فِی اللَّیْلِ الْأَلْیَلِ"
    },
    {
      "kind": "text",
      "ar": "وَالْمَاسِكِ مِنْ ٲَسْبَابِكَ بِحَبْلِ الشَّرَفِ الْاَطْوَلِ"
    },
    {
      "kind": "text",
      "ar": "وَالنَّاصِعِ الْحَسَبِ فِیْ ذِرْوَۃِ الْكَاھِلِ الْاَعْبَلِ"
    },
    {
      "kind": "text",
      "ar": "وَالثَّابِتِ الْقَدَمِ عَلٰی زَحَالِفِہَا فِی الزَّمَنِ الْاَوَّلِ"
    },
    {
      "kind": "text",
      "ar": "وَعَلٰی اٰلِہِ الْاَخْیَارِ الْمُصْطَفَیْنَ الْاَبْرَارِ"
    },
    {
      "kind": "text",
      "ar": "وَافْتَحِ اللّٰھُمَّ لَنَا مَصَارِیْعَ الصَّبَاحِ"
    },
    {
      "kind": "text",
      "ar": "بِمَفَاتِیْحِ الرَّحْمَۃِ وَالْفَلَاحِ"
    },
    {
      "kind": "text",
      "ar": "وَٲَلْبِسْنِی اللّٰھُمَّ مِنْ ٲَفْضَلِ خِلَعِ الْھِدَایَۃِ وَالصَّلَاحِ"
    },
    {
      "kind": "text",
      "ar": "وَٲَغْرِسِ اللّٰھُمَّ بِعَظَمَتِكَ فِیْ شِرْبِ جَنَانِیْ یَنَابِیْعَ الْخُشُوْعِ"
    },
    {
      "kind": "text",
      "ar": "وَٲَجْرِ اللّٰھُمَّ لِھَیْبَتِكَ مِنْ اٰمَاقِیْ زَفَرَاتِ الدُّمُوْعِ"
    },
    {
      "kind": "text",
      "ar": "وَٲَدِّبِ اللّٰھُمَّ نَزَقَ الْخُرْقِ مِنِّیْ بِٲَزِمَّۃِ الْقُنُوْعِ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ اِنْ لَمْ تَبْتَدِئْنِی الرَّحْمَۃُ مِنْكَ بِحُسْنِ التَّوْفِیْقِ"
    },
    {
      "kind": "text",
      "ar": "فَمَنِ السَّالِكُ بِیْ اِلَیْكَ فِیْ وَاضِحِ الطَّرِیْقِ"
    },
    {
      "kind": "text",
      "ar": "وَاِنْ ٲَسْلَمَتْنِیْ ٲَنَاتُكَ لِقَائِدِ الْاَمَلِ وَالْمُنٰی"
    },
    {
      "kind": "text",
      "ar": "فَمَنِ الْمُقِیْلُ عَثَرَاتِیْ مِنْ كَبَوَاتِ الْھَوٰی"
    },
    {
      "kind": "text",
      "ar": "وَاِنْ خَذَلَنِیْ نَصْرُكَ"
    },
    {
      "kind": "text",
      "ar": "عِنْدَ مُحَارَبَۃِ النَّفْسِ وَالشَّیْطَانِ"
    },
    {
      "kind": "text",
      "ar": "فَقَدْ وَكَلَنِیْ خِذْلَانُكَ اِلٰی حَیْثُ النَّصَبِ وَالْحِرْمَانِ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ ٲَتَرَانِیْ مَآ ٲَتَیْتُكَ اِلَّا مِنْ حَیْثُ الْاٰمَالِ"
    },
    {
      "kind": "text",
      "ar": "ٲَمْ عَلِقْتُ بِٲَطْرَافِ حِبَالِكَ"
    },
    {
      "kind": "text",
      "ar": "اِلَّا حِیْنَ بَاعَدَتْنِیْ ذُنُوْبِیْ عَنْ دَارِ الْوِصَالِ"
    },
    {
      "kind": "text",
      "ar": "فَبِئْسَ الْمَطِیَّۃُ الَّتِی امْتَطَتْ نَفْسِیْ مِنْ ھَوَاہَا"
    },
    {
      "kind": "text",
      "ar": "فَوَاہًا لَھَا لِمَا سَوَّلَتْ لَھَا ظُنُوْنُہَا وَمُنَاہَا"
    },
    {
      "kind": "text",
      "ar": "وَتَبًّا لَہَا لِجُرْٲَتِہَا عَلٰی سَیِّدِہَا وَمَوْلَاہَآ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ قَرَعْتُ بَابَ رَحْمَتِكَ بِیَدِ رَجَائِیْ"
    },
    {
      "kind": "text",
      "ar": "وَھَرَبْتُ اِلَیْكَ لَاجِئًا مِنْ فَرْطِ ٲَھْوَائِیْ"
    },
    {
      "kind": "text",
      "ar": "وَعَلَّقْتُ بِٲَطْرَافِ حِبَالِكَ ٲَنَامِلَ وَلَائِیْ"
    },
    {
      "kind": "text",
      "ar": "فَاصْفَحِ اللّٰھُمَّ عَمَّا كُنْتُ ٲَجْرَمْتُہٗ مِنْ زَلَلِیْ وَخَطَائِیْ"
    },
    {
      "kind": "text",
      "ar": "وَٲَقِلْنِیْ مِنْ صَرْعَۃِ رِدَائِیْ"
    },
    {
      "kind": "text",
      "ar": "فَاِنَّكَ سَیِّدِیْ وَمَوْلَایَ وَمُعْتَمَدِیْ وَرَجَائِیْ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْتَ غَایَۃُ مَطْلُوْبِیْ وَمُنَایَ فِیْ مُنْقَلَبِیْ وَمَثْوَایَ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ كَیْفَ تَطْرُدُ مِسْكِیْنًا"
    },
    {
      "kind": "text",
      "ar": "الْتَجَٲَ اِلَیْكَ مِنَ الذُّنُوْبِ ہَارِبًا"
    },
    {
      "kind": "text",
      "ar": "ٲَمْ كَیْفَ تُخَیِّبُ مُسْتَرْشِدًا"
    },
    {
      "kind": "text",
      "ar": "قَصَدَ اِلٰی جَنَابِكَ سَاعِیًا"
    },
    {
      "kind": "text",
      "ar": "ٲَمْ كَیْفَ تَرُدُّ ظَمْاٰنَ"
    },
    {
      "kind": "text",
      "ar": "وَرَدَ اِلٰی حِیَاضِكَ شَارِبًا"
    },
    {
      "kind": "text",
      "ar": "كَلَّا وَحِیَاضُكَ مُتْرَعَۃٌ فِیْ ضَنْكِ الْمُحُوْلِ"
    },
    {
      "kind": "text",
      "ar": "وَبَابُكَ مَفْتُوْحٌ لِّلطَّلَبِ وَالْوُغُوْلِ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْتَ غَایَۃُ الْمَسْؤُوْلِ وَنِھَایَۃُ الْمَٲْمُوْلِ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ ھٰذِہٖ ٲَزِمَّۃُ نَفْسِیْ"
    },
    {
      "kind": "text",
      "ar": "عَقَلْتُہَا بِعِقَالِ مَشِیَّتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَہٰذِہٖ ٲَعْبَاءُ ذُنُوْبِیْ"
    },
    {
      "kind": "text",
      "ar": "دَرَٲْتُہَا بِعَفْوِكَ وَرَحْمَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَھٰذِہٖ ٲَھْوَائِیَ الْمُضِلَّۃُ"
    },
    {
      "kind": "text",
      "ar": "وَكَلْتُہَا اِلٰی جَنَابِ لُطْفِكَ وَرَٲْفَتِكَ"
    },
    {
      "kind": "text",
      "ar": "فَاجْعَلِ اللّٰھُمَّ صَبَاحِیْ ھٰذَا نَازِلًا عَلَیَّ بِضِیَآءِ الْھُدٰی"
    },
    {
      "kind": "text",
      "ar": "وَبِالسَّلَامَۃِ فِی الدِّیْنِ وَالدُّنْیَا"
    },
    {
      "kind": "text",
      "ar": "وَمَسَائِیْ جُنَّۃً مِّنْ كَیْدِ الْعِدٰی"
    },
    {
      "kind": "text",
      "ar": "وَوِقَایَۃً مِنْ مُّرْدِیَاتِ الْھَوٰی"
    },
    {
      "kind": "text",
      "ar": "اِنَّكَ قَادِرٌ عَلٰی مَا تَشَآءُ"
    },
    {
      "kind": "text",
      "ar": "تُؤْتِی الْمُلْكَ مَنْ تَشَاءُ، وَتَنْزِعُ الْمُلْكَ مِمَّنْ تَشَآءُ"
    },
    {
      "kind": "text",
      "ar": "وَتُعِزُّ مَنْ تَشَآءُ، وَتُذِلُّ مَنْ تَشَآءُ"
    },
    {
      "kind": "text",
      "ar": "بِیَدِكَ الْخَیْرُ، اِنَّكَ عَلٰی كُلِّ شَیْءٍ قَدِیْرٌ"
    },
    {
      "kind": "text",
      "ar": "تُوْلِجُ اللَّیْلَ فِی النَّہَارِ، وَتُوْلِجُ النَّہَارَ فِی اللَّیْلِ"
    },
    {
      "kind": "text",
      "ar": "وَتُخْرِجُ الْحَیَّ مِنَ الْمَیِّتِ، وَتُخْرِجُ الْمَیِّتَ مِنَ الْحَیِّ"
    },
    {
      "kind": "text",
      "ar": "وَتَرْزُقُ مَنْ تَشَاءُ بِغَیْرِ حِسَابٍ"
    },
    {
      "kind": "text",
      "ar": "لَآ اِلٰہَ اِلَّا ٲَنْتَ سُبْحَانَكَ اللّٰھُمَّ وَبِحَمْدِكَ"
    },
    {
      "kind": "text",
      "ar": "مَنْ ذَا یَعْرِفُ قَدْرَكَ فَلَا یَخَافُكَ"
    },
    {
      "kind": "text",
      "ar": "وَمَنْ ذَا یَعْلَمُ مَآ ٲَنْتَ فَلَا یَہَابُكَ"
    },
    {
      "kind": "text",
      "ar": "ٲَلَّفْتَ بِقُدْرَتِكَ الْفِرَقَ"
    },
    {
      "kind": "text",
      "ar": "وَفَلَقْتَ بِلُطْفِكَ الْفَلَقَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنَرْتَ بِكَرَمِكَ دَیَاجِیَ الْغَسَقِ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْھَرْتَ الْمِیَاہَ مِنَ الصُّمِّ الصَّیَاخِیْدِ عَذْبًا وَّٲُجَاجًا"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْزَلْتَ مِنَ الْمُعْصِرَاتِ مَاءً ثَجَّاجًا"
    },
    {
      "kind": "text",
      "ar": "وَجَعَلْتَ الشَّمْسَ وَالْقَمَرَ لِلْبَرِیَّۃِ سِرَاجًا وَّہَّاجًا"
    },
    {
      "kind": "text",
      "ar": "مِنْ غَیْرِ ٲَنْ تُمَارِسَ فِیَمَا ابْتَدَٲْتَ بِہٖ لُغُوْبًا وَّلَا عِلَاجًا"
    },
    {
      "kind": "text",
      "ar": "فَیَا مَنْ تَوَحَّدَ بِالْعِزِّ وَالْبَقَآءِ"
    },
    {
      "kind": "text",
      "ar": "وَقَھَرَ عِبَادَہٗ بِالْمَوْتِ وَالْفَنَآءِ"
    },
    {
      "kind": "text",
      "ar": "صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِہِ الْاَتْقِیَآءِ"
    },
    {
      "kind": "text",
      "ar": "وَاسْمَعْ نِدَائِیْ وَاسْتَجِبْ دُعَآئِیْ"
    },
    {
      "kind": "text",
      "ar": "وَحَقِّقْ بِفَضْلِكَ ٲَمَلِیْ وَرَجَائِیْ"
    },
    {
      "kind": "text",
      "ar": "یَا خَیْرَ مَنْ دُعِیَ لِكَشْفِ الضُّرِّ"
    },
    {
      "kind": "text",
      "ar": "وَالْمَٲْمُوْلِ لِكُلِّ عُسْرٍ وَّیُسْرٍ"
    },
    {
      "kind": "text",
      "ar": "بِكَ ٲَنْزَلْتُ حَاجَتِیْ"
    },
    {
      "kind": "text",
      "ar": "فَلَا تَرُدَّنِیْ مِنْ سَنِیِّ مَوَاھِبِكَ خَائِبًا"
    },
    {
      "kind": "text",
      "ar": "یَا كَرِیْمُ یَا كَرِیْمُ یَا كَرِیْمُ"
    },
    {
      "kind": "text",
      "ar": "بِرَحْمَتِكَ یَا ٲَرْحَمَ الرَّاحِمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَصَلَّی اللہُ عَلٰی خَیْرِ خَلْقِہٖ مُحَمَّدٍ وَاٰلِہٖ ٲَجْمَعِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ قَلْبِیْ مَحْجُوْبٌ وَّنَفْسِیْ مَعْیُوْبٌ"
    },
    {
      "kind": "text",
      "ar": "وَعَقْلِیْ مَغْلُوْبٌ وَھَوَائِیْ غَالِبٌ"
    },
    {
      "kind": "text",
      "ar": "وَطَاعَتِیْ قَلِیْلٌ، وَمَعْصِیَتِیْ كَثِیْرٌ"
    },
    {
      "kind": "text",
      "ar": "وَلِسَانِیْ مُقِرٌّ بِالذُّنُوْبِ"
    },
    {
      "kind": "text",
      "ar": "فَكَیْفَ حِیْلَتِیْ یَا سَتَّارَ الْعُیُوْبِ"
    },
    {
      "kind": "text",
      "ar": "وَیَا عَلَّامَ الْغُیُوْبِ وَیَا كَاشِفَ الْكُرُوْبِ"
    },
    {
      "kind": "text",
      "ar": "اغْفِرْ ذُنُوْبِیْ كُلَّہَا بِحُرْمَۃِ مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ"
    },
    {
      "kind": "text",
      "ar": "یَّا غَفَّارُ یَا غَفَّارُ یَا غَفَّارُ"
    },
    {
      "kind": "text",
      "ar": "بِرَحْمَتِكَ یَا ٲَرْحَمَ الرَّاحِمِیْنَ"
    }
  ]
