    {
      "kind": "text",
      "ar": "وَاجْعَلْنِیْ لِنَعْمَائِكَ مِنَ الشَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَلِاٰلَائِكَ مِنَ الذَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "سَجَدَ وَجْھِیَ الذَّلِیْلُ لِوَجْھِكَ الْعَزِیْزِ الْجَلِیْلِ"
    },
    {
      "kind": "text",
      "ar": "سَجَدَ وَجْھِیَ الْبَالِي الْفَانِیْ لِوَجْھِكَ الدَّائِمِ الْبَاقِیْ"
    },
    {
      "kind": "text",
      "ar": "سَجَدَ وَجْھِیَ الْفَقِیْرُ لِوَجْھِكَ الْغَنِيِّ الْكَبِیْرِ"
    },
    {
      "kind": "text",
      "ar": "سَجَدَ وَجْھِیْ وَسَمْعِیْ وَبَصَرِیْ"
    },
    {
      "kind": "text",
      "ar": "وَلَحْمِیْ وَدَمِیْ وَجِلْدِیْ وَعَظْمِیْ"
    },
    {
      "kind": "text",
      "ar": "وَمَا ٲَقَلَّتِ الْاَرْضُ مِنِّیْ لِلّٰہِ رَبِّ الْعَالَمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ عُدْ عَلٰی جَھْلِیْ بِحِلْمِكَ"
    },
    {
      "kind": "text",
      "ar": "وَعَلٰی فَقْرِیْ بِغِنَاكَ"
    },
    {
      "kind": "text",
      "ar": "وَعَلٰی ذُلِّیْ بِعِزِّكَ وَسُلْطَانِكَ"
    },
    {
      "kind": "text",
      "ar": "وَعَلٰی ضَعْفِیْ بِقُوَّتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَعَلٰی خَوْفِیْ بِٲَمْنِكَ"
    },
    {
      "kind": "text",
      "ar": "وَعَلٰی ذُنُوْبِیْ وَخَطَایَایَ بِعَفْوِكَ وَرَحْمَتِكَ"
    },
    {
      "kind": "text",
      "ar": "یَا رَحْمٰنُ یَا رَحِیْمُ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنِّیْ ٲَدْرَٲُ بِكَ فِیْ نَحْرِ فُلَانِ بْنِ فُلَان"
    },
    {
      "kind": "text",
      "ar": "وَٲَعُوْذُ بِكَ مِنْ شَرِّہٖ"
    },
    {
      "kind": "text",
      "ar": "فَاكْفِنِیْہِ بِمَا كَفَیْتَ بِہٖ ٲَنْبِیَائَكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَوْ لِیَائَكَ مِنْ خَلْقِكَ، وَصَالِحِیْ عِبَادِكَ"
    },
    {
      "kind": "text",
      "ar": "مِنْ فَرَاعِنَۃِ خَلْقِكَ، وَطُغَاۃِ عُدَاتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَشَرِّ جَمِیْعِ خَلْقِكَ، بِرَحْمَتِكَ یَا ٲَرْحَمَ الرّاحِمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اِنَّكَ عَلٰی كُلِّ شَیْءٍ قَدِیْرٌ"
    },
    {
      "kind": "text",
      "ar": "وَحَسْبُنَا ﷲُ وَنِعْمَ الْوَكِیْلُ"
    }
  ]
}