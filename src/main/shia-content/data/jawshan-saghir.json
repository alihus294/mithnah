{
  "id": "jawshan-saghir",
  "title": "دعاء الجَوْشَن الصَّغير",
  "subtitle": "للإمام الكاظم عليه السلام",
  "source": "مفاتيح الجنان",
  "fiqh": "shia",
  "slides": [
    {
      "kind": "title",
      "ar": "دعاء الجَوْشَن الصَّغير",
      "subtitle": "للإمام الكاظم ع"
    },
    {
      "kind": "text",
      "ar": "بِسْمِ ﷲِ الرَّحْمٰنِ الرَّحِیْمِ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ كَمْ مِنْ عَدُوٍّ انْتَضٰی عَلَیَّ سَیْفَ عَدَاوَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَشَحَذَ لِیْ ظُبَۃَ مِدْیَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَٲَرْھَفَ لِیْ شَبَا حَدِّہٖ"
    },
    {
      "kind": "text",
      "ar": "وَدَافَ لِیْ قَوَاتِلَ سُمُوْمِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَسَدَّدَ اِلَیَّ صَوَائِبَ سِہَامِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَلَمْ تَنَمْ عَنِّیْ عَیْنُ حِرَاسَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَٲَضْمَرَ ٲَنْ یَسُوْمَنِی الْمَكْرُوْہَ"
    },
    {
      "kind": "text",
      "ar": "وَیُجَرِّعَنِیْ ذُعَافَ مَرَارَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "نَظَرْتَ اِلٰی ضَعْفِیْ عَنِ احْتِمَالِ الْفَوَادِحِ"
    },
    {
      "kind": "text",
      "ar": "وَعَجْزِیْ عَنِ الْاِنْتِصَارِ مِمَّنْ قَصَدَنِیْ بِمُحَارَبَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَوَحْدَتِیْ فِیْ كَثِیْرٍ مِمَّنْ نَاوَانِیْ"
    },
    {
      "kind": "text",
      "ar": "وَٲَرْصَدَ لِیْ فِیْمَا لَمْ ٲُعْمِلْ فِكْرِیْ فِی الْاِرْصَادِ لَھُمْ بِمِثْلِہٖ"
    },
    {
      "kind": "text",
      "ar": "فَٲَیَّدْتَنِیْ بِقُوَّتِكَ، وَشَدَدْتَ ٲَزْرِیْ بِنُصْرَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَفَلَلْتَ لِیْ حَدَّہٗ وَخَذَلْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "بَعْدَ جَمْعِ عَدِیْدِہٖ وَحَشْدِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَٲَعْلَیْتَ كَعْبِیْ عَلَیْہِ"
    },
    {
      "kind": "text",
      "ar": "وَوَجَّھْتَ مَا سَدَّدَ اِلَیَّ مِنْ مَكَائِدِہٖ اِلَیْہ وَرَدَدْتَہٗ عَلَیْہِ"
    },
    {
      "kind": "text",
      "ar": "وَلَمْ یَشْفِ غَلِیْلَہٗ، وَلَمْ تَبْرُدْ حَزَازَاتُ غَیْظِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَقَدْ عَضَّ عَلَیَّ ٲَنَامِلَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَٲَدْبَرَ مُوَلِّیًا قَدْ ٲَخْفَقَتْ سَرَایَاہُ"
    },
    {
      "kind": "text",
      "ar": "فَلَكَ الْحَمْدُ یَا رَبِّ"
    },
    {
      "kind": "text",
      "ar": "مِنْ مُقْتَدِرٍ لَا یُغْلَبُ، وَذِیْ ٲَنَاۃٍ لَا یَعْجَل"
    },
    {
      "kind": "text",
      "ar": "صَلِّ عَلٰی مُحَمَّدٍ وَاٰلِ مُحَمَّدٍ"
    },
    {
      "kind": "text",
      "ar": "وَاجْعَلْنِیْ لِنَعْمَائِكَ مِن الشَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَلِاٰلَائِكَ مِنَ الذَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ وَكَمْ مِنْ بَاغٍ بَغَانِیْ بِمَكَائِدِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَنَصَبَ لِیْ ٲَشْرَاكَ مَصَائِدِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَوَكَّلَ بِیْ تَفَقُّدَ رِعَایَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَٲَضْبَٲَ اِلَیَّ اِضْبَاءَ السَّبُعِ لِطَرِیْدَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "انْتِظَارًا لِاِنْتِہَازِ فُرْصَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَھُوَ یُظْھِرُ بَشَاشَۃَ الْمَلَقِ"
    },
    {
      "kind": "text",
      "ar": "وَیَبْسُطُ وَجْہًا غَیْرَ طَلِقٍ"
    },
    {
      "kind": "text",
      "ar": "فَلَمّا رَٲَیْتَ دَغَلَ سَرِیْرَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَقُبْحَ مَا انْطَوٰی عَلَیْہِ لِشَرِیْكِہٖ فِیْ مِلَّتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَٲَصْبَحَ مُجْلِبًا لِیْ فِیْ بَغْیِہٖ ٲَرْكَسْتَہٗ لِاُمِّ رَٲْسِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَٲَتَیْتَ بُنْیَانَہٗ مِنْ ٲَسَاسِہٖ"
    },
    {
      "kind": "text",
      "ar": "فَصَرَعْتَہٗ فِیْ زُبْیَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَرَدَّیْتَہٗ فِیْ مَھْوٰی حُفْرَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَجَعَلْتَ خَدَّہٗ طَبَقًا لِتُرَابِ رِجْلِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَشَغَلْتَہٗ فِیْ بَدَنِہٖ وَرِزْقِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَرَمَیْتَہٗ بِحَجَرِہٖ، وَخَنَقْتَہٗ بِوَتَرِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَذَكَّیْتَہٗ بِمَشَاقِصِہٖ، وَكَبَبْتَہٗ لِمَنْخِرِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَرَدَدْتَ كَیْدَہٗ فِیْ نَحْرِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَرَبَقْتَہٗ بِنَدَامَتِہٖ، وَفَسَٲْتَہٗ بِحَسْرَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "فَاسْتَخْذَٲَ وَتَضَائَلَ بَعْدَ نَخْوَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَانْقَمَعَ بَعْدَ اسْتِطَالَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "ذَلِیْلًا مَٲْسُوْرًا فِیْ رِبْقِ حِبَالَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "الَّتِیْ كَانَ یُؤَمِّلُ ٲَنْ یَرَانِیْ فِیْہَا یَوْمَ سَطْوَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَقَدْ كِدْتُ یَا رَبِّ لَوْ لَا رَحْمَتُكَ"
    },
    {
      "kind": "text",
      "ar": "ٲَنْ یَحُلَّ بِیْ مَا حَلَّ بِسَاحَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "فَلَكَ الْحَمْدُ یَا رَبِّ"
    },
    {
      "kind": "text",
      "ar": "مِنْ مُقْتَدِرٍ لَا یُغْلَبُ، وَذِیْ ٲَنَاۃٍ لَا یَعْجَلُ"
    },
    {
      "kind": "text",
      "ar": "صَلِّ عَلٰی مُحَمَّدٍ وَاٰلِ مُحَمَّدٍ"
    },
    {
      "kind": "text",
      "ar": "وَاجْعَلْنِیْ لِنَعْمَائِكَ مِنَ الشَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَلِاٰلَائِكَ مِنَ الذَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ وَكَمْ مِنْ حَاسِدٍ شَرِقَ بِحَسْرَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَعَدُوٍّ شَجِیَ بِغَیْظِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَسَلَقَنِیْ بِحَدِّ لِسَانِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَوَخَزَنِیْ بِمُوْقِ عَیْنِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَجَعَلَنِیْ غَرَضًا لِمَرَامِیْہِ"
    },
    {
      "kind": "text",
      "ar": "وَقَلَّدَنِیْ خِلَالًا لَمْ تَزَلْ فِیْہِ"
    },
    {
      "kind": "text",
      "ar": "نَادَیْتُكَ یَا رَبِّ مُسْتَجِیْرًا بِكَ"
    },
    {
      "kind": "text",
      "ar": "وَاثِقًا بِسُرْعَۃِ اِجَابَتِكَ"
    },
    {
      "kind": "text",
      "ar": "مُتَوَكِّلًا عَلٰی مَا لَمْ ٲَزَلْ ٲَتَعَرَّفُہٗ مِنْ حُسْنِ دِفَاعِكَ"
    },
    {
      "kind": "text",
      "ar": "عَالِمًا ٲَنَّہٗ لَا یُضْطَھَدُ مَنْ ٲَوٰی اِلٰی ظِلِّ كَنَفِكَ"
    },
    {
      "kind": "text",
      "ar": "وَلَنْ تَقْرَعَ الْحَوَادِثُ مَنْ لَجَٲَ اِلٰی مَعْقِلِ الْاِنْتِصَارِ بِكَ"
    },
    {
      "kind": "text",
      "ar": "فَحَصَّنْتَنِیْ مِنْ بَٲْسِہٖ بِقُدْرَتِكَ"
    },
    {
      "kind": "text",
      "ar": "فَلَكَ الْحَمْدُ یَا رَبِّ"
    },
    {
      "kind": "text",
      "ar": "مِنْ مُقْتَدِرٍ لَا یُغْلَبُ، وَذِیْ ٲَنَاۃٍ لَا یَعْجَلُ"
    },
    {
      "kind": "text",
      "ar": "صَلِّ عَلٰی مُحَمَّدٍ وَاٰلِ مُحَمَّدٍ"
    },
    {
      "kind": "text",
      "ar": "وَاجْعَلْنِیْ لِنَعْمَائِكَ مِنَ الشَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَلِاٰلَائِكَ مِنَ الذَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ وَكَمْ مِنْ سَحَائِبِ مَكْرُوْہٍ جَلَّیْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَسَمَاءِ نِعْمَۃٍ مَطَرْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَجَدَاوِلِ كَرَامَۃٍ ٲَجْرَیْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَٲَعْیُنِ ٲَحْدَاثٍ طَمَسْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَنَاشِیَۃِ رَحْمَۃٍ نَشَرْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَجُنَّۃِ عَافِیَۃٍ ٲَلْبَسْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَغَوَامِرِ كُرُبَاتٍ كَشَفْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَٲُمُوْرٍ جَارِیَۃٍ قَدَّرْتَہَا"
    },
    {
      "kind": "text",
      "ar": "لَمْ تُعْجِزْكَ اِذْ طَلَبْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَلَمْ تَمْتَنِعْ مِنْكَ اِذْ ٲَرَدْتَہَا"
    },
    {
      "kind": "text",
      "ar": "فَلَكَ الْحَمْدُ یَا رَبِّ"
    },
    {
      "kind": "text",
      "ar": "مِنْ مُقْتَدِرٍ لَا یُغْلَبُ، وَذِیْ ٲَنَاۃٍ لَا یَعْجَلُ"
    },
    {
      "kind": "text",
      "ar": "صَلِّ عَلٰی مُحَمَّدٍ وَاٰلِ مُحَمَّدٍ"
    },
    {
      "kind": "text",
      "ar": "وَاجْعَلْنِیْ لِنَعْمَائِكَ مِنَ الشَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَلِاٰلَائِكَ مِنَ الذَّاكِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ وَكَمْ مِنْ ظَنٍّ حَسَنٍ حَقَّقْتَ"
    },
    {
      "kind": "text",
      "ar": "وَمِنْ كَسْرِ اِمْلَاقٍ جَبَرْتَ"
    },
    {
      "kind": "text",
      "ar": "وَمِنْ مَسْكَنَۃٍ فَادِحَۃٍ حَوَّلْتَ"
    },
    {
      "kind": "text",
      "ar": "وَمِنْ صَرْعَۃٍ مُھْلِكَۃٍ نَعَشْتَ"
    },
    {
      "kind": "text",
      "ar": "وَمِنْ مَشَقَّۃٍ ٲَرَحْتَ"
    },
    {
      "kind": "text",
      "ar": "لَا تُسْٲَلُ عَمَّا تَفْعَلُ وَھُمْ یُسْٲَلُوْنَ"
    },
    {
      "kind": "text",
      "ar": "وَلَا یَنْقُصُكَ مَا ٲَنْفَقْتَ"
    },
    {
      "kind": "text",
      "ar": "وَلَقَدْ سُئِلْتَ فَٲَعْطَیْتَ، وَلَمْ تُسْٲَلْ فَابْتَدَٲْتَ"
    },
    {
      "kind": "text",
      "ar": "وَاسْتُمِیْحَ بَابُ فَضْلِكَ فَمَا ٲَكْدَیْتَ ٲَبَیْتَ"
    },
    {
      "kind": "text",
      "ar": "اِلَّا اِنْعَامًا وَامْتِنَانًا وَاِلَّا تَطَوُّلًا یَا رَبِّ وَاِحْسَانًا"
    },
    {
      "kind": "text",
      "ar": "وَٲَبَیْتُ اِلَّا انْتِہَاكًا لِحُرُمَاتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَاجْتِرَاءً عَلٰی مَعَاصِیْكَ"
    },
    {
      "kind": "text",
      "ar": "وَتَعَدِیًّا لِحُدُوْدِكَ، وَغَفْلَۃً عَنْ وَعِیْدِكَ"
    },
    {
      "kind": "text",
      "ar": "وَطَاعَۃً لِعَدُوِّیْ وَعَدُوِّكَ"
    },
    {
      "kind": "text",
      "ar": "لَمْ یَمْنَعْكَ یَا اِلٰھِیْ وَنَاصِرِیْ"
    },
    {
      "kind": "text",
      "ar": "اِخْلَالِیْ بِالشُّكْرِ  عَنْ اِتْمَامِ اِحْسَانِكَ"
    },
    {
      "kind": "text",
      "ar": "وَلَا حَجَزَنِیْ ذٰلِكَ عَنِ ارْتِكَابِ مَسَاخِطِكَ"
    },
