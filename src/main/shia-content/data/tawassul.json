      "ar": "یَا سَادَتِیْ یَا ٲَوْ لِیَاءَ اللہِ"
    },
    {
      "kind": "text",
      "ar": "صَلَّی اللہُ عَلَیْھِمْ ٲَجْمَعِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَلَعَنَ اللہُ ٲَعْدَاءَ اللہِ ظَالِمِیْھِمْ"
    },
    {
      "kind": "text",
      "ar": "مِنَ الْاَوَّلِیْنَ وَالْاٰخِرِیْنَ اٰمِیْنَ رَبَّ الْعَالَمِیْنَ"
    }
  ]
}