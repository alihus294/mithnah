{
  "id": "iftitah",
  "title": "دعاء الافتتاح",
  "subtitle": "دعاء شهر رمضان المبارك",
  "source": "مفاتيح الجنان",
  "fiqh": "shia",
  "slides": [
    {
      "kind": "title",
      "ar": "دعاء الافتتاح",
      "subtitle": "دعاء شهر رمضان المبارك"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنِّیْ ٲَفْتَتِحُ الثَّنَاءَ بِحَمْدِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْتَ مُسَدِّدٌ لِلصَّوَابِ بِمَنِّكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَیْقَنْتُ ٲَنَّكَ ٲَنْتَ ٲَرْحَمُ الرَّاحِمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "فِیْ مَوْضِعِ الْعَفْوِ وَالرَّحْمَۃِ"
    },
    {
      "kind": "text",
      "ar": "وَٲَشَدُّ الْمُعَاقِبِیْنَ فِیْ مَوْضِعِ النَّكَالِ وَالنَّقِمَۃِ"
    },
    {
      "kind": "text",
      "ar": "وَٲَعْظَمُ الْمُتَجَبِّرِیْنَ فِیْ مَوْضِعِ الْكِبْرِیَاءِ وَالْعَظَمَۃِ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ ٲَذِنْتَ لِیْ فِیْ دُعَائِكَ وَمَسْٲَلَتِكَ"
    },
    {
      "kind": "text",
      "ar": "فَاسْمَعْ یَا سَمِیْعُ مِدْحَتِیْ"
    },
    {
      "kind": "text",
      "ar": "وَٲَجِبْ یَا رَحِیْمُ دَعْوَتِیْ"
    },
    {
      "kind": "text",
      "ar": "وَٲَقِلْ یَا غَفُوْرُ عَثْرَتِیْ"
    },
    {
      "kind": "text",
      "ar": "فَكَمْ یَا اِلٰھِیْ مِنْ كُرْبَۃٍ قَدْ فَرَّجْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَھُمُوْمٍ قَدْ كَشَفْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَعَثْرَۃٍ قَدْ ٲَقَلْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَرَحْمَۃٍ قَدْ نَشَرْتَہَا"
    },
    {
      "kind": "text",
      "ar": "وَحَلْقَۃِ بَلَاءٍ قَدْ فَكَكْتَہَا"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ لَمْ یَتَّخِذْ صَاحِبَۃً وَلَا وَلَدًا"
    },
    {
      "kind": "text",
      "ar": "وَلَمْ یَكُنْ لَہٗ شَرِیْكٌ فِی الْمُلْكِ"
    },
    {
      "kind": "text",
      "ar": "وَلَمْ یَكُنْ لَہٗ وَلِیٌّ مِنَ الذُّلِّ"
    },
    {
      "kind": "text",
      "ar": "وَكَبِّرْھُ تَكْبِیْرًا"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ بِجَمِیْعِ مَحَامِدِھٖ كُلِّہَا"
    },
    {
      "kind": "text",
      "ar": "عَلٰی جَمِیْعِ نِعَمِہٖ كُلِّہَا"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ لَا مُضَادَّ لَہٗ فِیْ مُلْكِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَلَا مُنَازِعَ لَہٗ فِیْ ٲَمْرِھٖ۔"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ لَا شَرِیْكَ لَہٗ فِیْ خَلْقِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَلَا شَبِیْہَ لَہٗ فِیْ عَظَمَتِہٖ۔"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الْفَاشِیْ فِی الْخَلْقِ ٲَمْرُھٗ وَحَمْدُھٗ"
    },
    {
      "kind": "text",
      "ar": "الظَّاھِرِ بِالْكَرَمِ مَجْدُھٗ"
    },
    {
      "kind": "text",
      "ar": "الْبَاسِطِ بِالْجُوْدِ یَدَھٗ"
    },
    {
      "kind": "text",
      "ar": "الَّذِیْ لَا تَنْقُصُ خَزَائِنُہٗ"
    },
    {
      "kind": "text",
      "ar": "وَلَا تَزِیْدُھٗ كَثْرَۃُ الْعَطَاءِ اِلَّا جُوْدًا وَكَرَمًا"
    },
    {
      "kind": "text",
      "ar": "اِنَّہٗ ھُوَ الْعَزِیْزُ الْوَہَّابُ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنِّیْ ٲَسْٲَلُكَ قَلِیْلًا مِنْ كَثِیْرٍ"
    },
    {
      "kind": "text",
      "ar": "مَعَ حَاجَۃٍ بِیْ اِلَیْہِ عَظِیْمَۃٍ"
    },
    {
      "kind": "text",
      "ar": "وَغِنَاكَ عَنْہُ قَدِیْمٌ، وَھُوَ عِنْدِیْ كَثِیْرٌ"
    },
    {
      "kind": "text",
      "ar": "وَھُوَ عَلَیْكَ سَھْلٌ یَسِیْرٌ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنَّ عَفْوَكَ عَنْ ذَنْبِیْ"
    },
    {
      "kind": "text",
      "ar": "وَتَجَاوُزَكَ عَنْ خَطِیْئَتِیْ"
    },
    {
      "kind": "text",
      "ar": "وَصَفْحَكَ عَنْ ظُلْمِیْ"
    },
    {
      "kind": "text",
      "ar": "وَسَتْرَكَ عَلٰی قَبِیْحِ عَمَلِیْ"
    },
    {
      "kind": "text",
      "ar": "وَحِلْمَكَ عَنْ كَثِیْرِ جُرْمِیْ"
    },
    {
      "kind": "text",
      "ar": "عِنْدَ مَا كَانَ مِنْ خَطَاِیْ وَعَمْدِیْ"
    },
    {
      "kind": "text",
      "ar": "ٲَطْمَعَنِیْ فِیْ ٲَنْ ٲَسْٲَلَكَ مَا لَا ٲَسْتَوْجِبُہٗ مِنْكَ"
    },
    {
      "kind": "text",
      "ar": "الَّذِیْ رَزَقْتَنِیْ مِنْ رَحْمَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَرَیْتَنِیْ مِنْ قُدْرَتِكَ، وَعَرَّفْتَنِیْ مِنْ اِجَابَتِكَ"
    },
    {
      "kind": "text",
      "ar": "فَصِرْتُ ٲَدْعُوْكَ اٰمِنًا"
    },
    {
      "kind": "text",
      "ar": "وَٲَسْٲَلُكَ مُسْتَٲْنِسًا لَا خَائِفًا وَلَا وَجِلًا"
    },
    {
      "kind": "text",
      "ar": "مُدِلًّا عَلَیْكَ فِیْمَا قَصَدْتُ فِیْہِ اِلَیْكَ"
    },
    {
      "kind": "text",
      "ar": "فَاِنْ ٲَبْطَٲَ عَنِّیْ عَتَبْتُ بِجَھْلِیْ عَلَیْكَ"
    },
    {
      "kind": "text",
      "ar": "وَلَعَلَّ الَّذِیْ ٲَبْطَٲَ عَنِّیْ ھُوَ خَیْرٌ لِیْ"
    },
    {
      "kind": "text",
      "ar": "لِعِلْمِكَ بِعَاقِبَۃِ الْاُمُوْرِ"
    },
    {
      "kind": "text",
      "ar": "فَلَمْ ٲَرَ مَوْلًى كَرِیْمًا"
    },
    {
      "kind": "text",
      "ar": "ٲَصْبَرَ عَلٰی عَبْدٍ لَئِیْمٍ مِنْكَ عَلَیَّ"
    },
    {
      "kind": "text",
      "ar": "یَا رَبِّ، اِنَّكَ تَدْعُوْنِیْ فَٲُوَلِّیْ عَنْكَ"
    },
    {
      "kind": "text",
      "ar": "وَتَتَحَبَّبُ اِلَیَّ فٲَتَبَغَّضُ اِلَیْكَ"
    },
    {
      "kind": "text",
      "ar": "وَتَتَوَدَّدُ اِلَیَّ فَلَا ٲَقْبَلُ مِنْكَ"
    },
    {
      "kind": "text",
      "ar": "كَٲَنَّ لِیَ التَّطَوُّلَ عَلَیْكَ"
    },
    {
      "kind": "text",
      "ar": "فَلَمْ یَمْنَعْكَ ذٰلِكَ مِنَ الرَّحْمَۃِ لِیْ"
    },
    {
      "kind": "text",
      "ar": "وَالْاِحْسَانِ اِلَیَّ، وَالتَّفَضُّلِ عَلَیَّ بِجُوْدِكَ وَكَرَمِكَ"
    },
    {
      "kind": "text",
      "ar": "فَارْحَمْ عَبْدَكَ الْجَاھِلَ"
    },
    {
      "kind": "text",
      "ar": "وَجُدْ عَلَیْہِ بِفَضْلِ اِحْسَانِكَ"
    },
    {
      "kind": "text",
      "ar": "اِنَّكَ جَوَادٌ كَرِیْمٌ۔"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ مَالِكِ الْمُلْكِ، مُجْرِی الْفُلْكِ"
    },
    {
      "kind": "text",
      "ar": "مُسَخِّرِ الرِّیَاحِ، فَالِقِ الْاِصْبَاحِ"
    },
    {
      "kind": "text",
      "ar": "دَیَّانِ الدِّیْنِ، رَبِّ الْعَالَمِیْنَ۔"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ عَلٰی حِلْمِہٖ بَعْدَ عِلْمِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَالْحَمْدُ لِلّٰہِ عَلٰی عَفْوِھٖ بَعْدَ قُدْرَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَالْحَمْدُ لِلّٰہِ عَلٰی طُوْلِ ٲَنَاتِہٖ فِیْ غَضَبِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَھُوَ قَادِرٌ عَلٰی مَا یُرِیْدُ۔"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ خَالِقِ الْخَلْقِ"
    },
    {
      "kind": "text",
      "ar": "بَاسِطِ الرِّزْقِ، فَالِقِ الْاِصْبَاحِ"
    },
    {
      "kind": "text",
      "ar": "ذِی الْجَلَالِ وَالْاِكْرَامِ وَالْفَضْلِ وَالْاِنْعَامِ"
    },
    {
      "kind": "text",
      "ar": "الَّذِیْ بَعُدَ فَلَا یُرٰی"
    },
    {
      "kind": "text",
      "ar": "وَقَرُبَ فَشَھِدَ النَّجْوٰی"
    },
    {
      "kind": "text",
      "ar": "تَبَارَكَ وَتَعَالٰی"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ لَیْسَ لَہٗ مُنَازِعٌ یُعَادِلُہٗ"
    },
    {
      "kind": "text",
      "ar": "وَلَا شَبِیْہٌ یُشَاكِلُہٗ، وَلَا ظَھِیْرٌ یُعَاضِدُہٗ"
    },
    {
      "kind": "text",
      "ar": "قَھَرَ بِعِزَّتِہِ الْاَعِزَّاءَ"
    },
    {
      "kind": "text",
      "ar": "وَتَوَاضَعَ لِعَظَمَتِہِ الْعُظَمَاءُ"
    },
    {
      "kind": "text",
      "ar": "فَبَلَغَ بِقُدْرَتِہٖ مَا یَشَاءُ۔"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ یُجِیْبُنِیْ حِیْنَ ٲُنَادِیْہِ"
    },
    {
      "kind": "text",
      "ar": "وَیَسْتُرُ عَلَیَّ كُلَّ عَوْرَۃٍ وَٲَنَا ٲَعْصِیْہِ"
    },
    {
      "kind": "text",
      "ar": "وَیُعَظِّمُ النِّعْمَۃَ عَلَیَّ فَلَا ٲُجَازِیْہِ"
    },
    {
      "kind": "text",
      "ar": "فَكَمْ مِنْ مَوْھِبَۃٍ ھَنِیْئَۃٍ قَدْ ٲَعْطَانِیْ"
    },
    {
      "kind": "text",
      "ar": "وَعَظِیْمَۃٍ مَخُوْفَۃٍ قَدْ كَفَانِیْ"
    },
    {
      "kind": "text",
      "ar": "وَبَھْجَۃٍ مُوْنِقَۃٍ قَدْ ٲَرَانِیْ"
    },
    {
      "kind": "text",
      "ar": "فَٲُثْنِیْ عَلَیْہِ حَامِدًا"
    },
    {
      "kind": "text",
      "ar": "وَٲَذْكُرُھٗ مُسَبِّحًا۔"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ لَا یُھْتَكُ حِجَابُہٗ"
    },
    {
      "kind": "text",
      "ar": "وَلَا یُغْلَقُ بَابُہٗ، وَلَا یُرَدُّ سَائِلُہٗ"
    },
    {
      "kind": "text",
      "ar": "وَلَا یُخَیَّبُ اٰمِلُہٗ"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ یُؤْمِنُ الْخَائِفِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَیُنَجِّی الصَّالِحِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَیَرْفَعُ الْمُسْتَضْعَفِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَیَضَعُ الْمُسْتَكْبِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَیُھْلِكُ مُلُوْكًا وَیَسْتَخْلِفُ اٰخَرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَالْحَمْدُ لِلّٰہِ قَاصِمِ الْجَبَّارِیْنَ"
    },
    {
      "kind": "text",
      "ar": "مُبِیْرِ الظَّالِمِیْنَ، مُدْرِكِ الْہَارِبِیْنَ"
    },
    {
      "kind": "text",
      "ar": "نَكَالِ الظَّالِمِیْنَ، صَرِیْخِ الْمُسْتَصْرِخِیْنَ"
    },
    {
      "kind": "text",
      "ar": "مَوْضِعِ حَاجَاتِ الطَّالِبِیْنَ"
    },
    {
      "kind": "text",
      "ar": "مُعْتَمَدِ الْمُؤْمِنِیْنَ"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ مِنْ خَشْیَتِہٖ تَرْعَدُ السَّمَاءُ وَسُكَّانُہَا"
    },
    {
      "kind": "text",
      "ar": "وَتَرْجُفُ الْاَرْضُ وَعُمَّارُہَا"
    },
    {
      "kind": "text",
      "ar": "وَتَمُوْجُ الْبِحَارُ وَمَنْ یَسْبَحُ فِیْ غَمَرَاتِہَا"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ ھَدَانَا لِہٰذَا"
    },
    {
      "kind": "text",
      "ar": "وَمَا كُنَّا لِنَھْتَدِیَ لَوْ لَا ٲَنْ ھَدَانَا ﷲُ۔"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ الَّذِیْ یَخْلُقُ وَلَمْ یُخْلَقْ"
    },
    {
      "kind": "text",
      "ar": "وَیَرْزُقُ وَلَا یُرْزَقُ"
    },
    {
      "kind": "text",
      "ar": "وَیُطْعِمُ وَلَا یُطْعَمُ"
    },
    {
      "kind": "text",
      "ar": "وَیُمِیْتُ الْاَحْیَاءَ وَیُحْیِی الْمَوْتٰی"
    },
    {
      "kind": "text",
      "ar": "وَھُوَ حَیٌّ لَا یَمُوْتُ، بِیَدِہِ الْخَیْرُ"
    },
    {
      "kind": "text",
      "ar": "وَھُوَ عَلٰی كُلِّ شَیْءٍ قَدِیْرٌ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ صَلِّ عَلٰی مُحَمَّدٍ عَبْدِكَ وَرَسُوْلِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَمِیْنِكَ وَصَفِیِّكَ وَحَبِیْبِكَ"
    },
    {
      "kind": "text",
      "ar": "وَخِیَرَتِكَ مِنْ خَلْقِكَ"
    },
    {
      "kind": "text",
      "ar": "وَحَافِظِ سِرِّكَ، وَمُبَلِّغِ رِسَالَاتِكَ"
    },
    {
      "kind": "text",
      "ar": "ٲَفْضَلَ وَٲَحْسَنَ وَٲَجْمَلَ وَٲَكْمَلَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَزْكٰی وَٲَنْمٰی وَٲَطْیَبَ وَٲَطْھَرَ وَٲَسْنٰی"
    },
    {
      "kind": "text",
      "ar": "وَٲَكْثَرَ مَا صَلَّیْتَ وَبَارَكْتَ وَتَرَحَّمْتَ وَتَحَنَّنْتَ"
    },
    {
      "kind": "text",
      "ar": "وَسَلَّمْتَ عَلٰی ٲَحَدٍ مِنْ عِبَادِكَ وَٲَنْبِیَائِكَ وَرُسُلِكَ"
    },
    {
      "kind": "text",
      "ar": "وَصِفْوَتِكَ وَٲَھْلِ الْكَرَامَۃِ عَلَیْكَ مِنْ خَلْقِكَ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ وَصَلِّ عَلٰی عَلِیٍّ ٲَمِیْرِ الْمُؤْمِنِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَوَصِیِّ رَسُوْلِ رَبِّ الْعَالَمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "عَبْدِكَ وَوَلِیِّكَ وَٲَخِیْ رَسُوْلِكَ"
    },
    {
      "kind": "text",
      "ar": "وَحُجَّتِكَ عَلٰی خَلْقِكَ"
    },
    {
      "kind": "text",
      "ar": "وَاٰیَتِكَ الْكُبْرٰی، وَالنَّبَاِ الْعَظِیْمِ"
    },
    {
      "kind": "text",
      "ar": "وَصَلِّ عَلَی الصِّدِّیْقَۃِ الطَّاھِرَۃِ فَاطِمَۃَ"
    },
    {
      "kind": "text",
      "ar": "سَیِّدَۃِ نِسَاءِ الْعَالَمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَصَلِّ عَلٰی سِبْطَیِ الرَّحْمَۃِ"
    },
    {
      "kind": "text",
      "ar": "وَاِمَامَیِ الْھُدٰی الْحَسَنِ وَالْحُسَیْنِ"
    },
    {
      "kind": "text",
      "ar": "سَیِّدَیْ شَبَابِ ٲَھْلِ الْجَنَّۃِ"
    },
    {
      "kind": "text",
      "ar": "وَصَلِّ عَلٰی ٲَئِمَّۃِ الْمُسْلِمِیْنِ"
    },
    {
      "kind": "text",
      "ar": "عَلِیِّ بْنِ الْحُسَیْنِ"
    },
    {
      "kind": "text",
      "ar": "وَمُحَمَّدِ بْنِ عَلِیٍّ، وَجَعْفَرِ بْنِ مُحَمَّدٍ"
    },
    {
      "kind": "text",
      "ar": "وَمُوْسَی بْنِ جَعْفَرٍ، وَعَلِیِّ بْنِ مُوْسٰی"
    },
    {
      "kind": "text",
      "ar": "وَمُحَمَّدِ بْنِ عَلِیٍّ، وَعَلِیِّ بْنِ مُحَمَّدٍ"
    },
    {
      "kind": "text",
      "ar": "وَالْحَسَنِ بْنِ عَلِیٍّ، وَالْخَلَفِ الْہَادِی الْمَھْدِیِّ"
    },
    {
      "kind": "text",
      "ar": "حُجَجِكَ عَلٰی عِبَادِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲُمَنَائِكَ فِیْ بِلَادِكَ"
    },
    {
      "kind": "text",
      "ar": "صَلَاۃً كَثِیْرَۃً دَائِمَۃً۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ وَصَلِّ عَلٰی وَلیِّ ٲَمْرِكَ الْقَائِمِ"
    },
    {
      "kind": "text",
      "ar": "الْمُؤَمَّلِ، وَالْعَدْلِ الْمُنْتَظَرِ"
    },
    {
      "kind": "text",
      "ar": "وَحُفَّہٗ بِمَلَائِكَتِكَ الْمُقَرَّبِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَیِّدْہُ بِرُوْحِ الْقُدُسِ یَا رَبَّ الْعَالَمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اجْعَلْہُ الدَّاعِیَ اِلٰی كِتَابِكَ"
    },
    {
      "kind": "text",
      "ar": "وَالْقَائِمَ بِدِیْنِكَ"
    },
    {
      "kind": "text",
      "ar": "اسْتَخْلِفْہُ فِی الْاَرْضِ كَمَا اسْتَخْلَفْتَ الَّذِیْنَ مِنْ قَبْلِہٖ"
    },
    {
      "kind": "text",
      "ar": "مَكِّنْ لَہٗ دِیْنَہُ الَّذِی ارْتَضَیْتَہٗ لَہٗ"
    },
    {
      "kind": "text",
      "ar": "ٲَبْدِلْہُ مِنْ بَعْدِ خَوْفِہٖ ٲَمْنًا"
    },
    {
      "kind": "text",
      "ar": "یَعْبُدُكَ لَا یُشْرِكُ بِكَ شَیْئًا۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ ٲَعِزَّھٗ وَٲَعْزِزْ بِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَانْصُرْھُ وَانْتَصِرْ بِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَانْصُرْھُ نَصْرًا عَزِیْزًا"
    },
    {
      "kind": "text",
      "ar": "وَافْتَحْ لَہٗ فَتْحًا یَسِیْرًا"
    },
    {
      "kind": "text",
      "ar": "وَاجْعَلْ لَہٗ مِنْ لَدُنْكَ سُلْطَانًا نَصِیْرًا"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ ٲَظْھِرْ بِہٖ دِیْنَكَ وَسُنَّۃَ نَبِیِّكَ"
    },
    {
      "kind": "text",
      "ar": "حَتّٰی لَا یَسْتَخْفِیَ بِشَیْءٍ مِنَ الْحَقِّ"
    },
    {
      "kind": "text",
      "ar": "مَخَافَۃَ ٲَحَدٍ مِنَ الْخَلْقِ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنَّا نَرْغَبُ اِلَیْكَ فِیْ دَوْلَۃٍ كَرِیْمَۃٍ"
    },
    {
      "kind": "text",
      "ar": "تُعِزُّ بِھَا الْاِسْلَامَ وَٲَھْلَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَتُذِلُّ بِھَا النِّفَاقَ وَٲَھْلَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَتَجْعَلُنَا فِیْہَا مِنَ الدُّعَاۃِ اِلٰی طَاعَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَالْقَادَۃِ اِلٰی سَبِیْلِكَ"
    },
    {
      "kind": "text",
      "ar": "وَتَرْزُقُنَا بِہَا كَرَامَۃَ الدُّنْیَا وَالْاٰخِرَۃِ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ مَا عَرَّفْتَنَا مِنَ الْحَقِّ فَحَمِّلْنَاھُ"
    },
    {
      "kind": "text",
      "ar": "وَمَا قَصُرْنَا عَنْہُ فَبَلِّغْنَاھُ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ الْمُمْ بِہٖ شَعَثَنَا"
    },
    {
      "kind": "text",
      "ar": "وَاشْعَبْ بِہٖ صَدْعَنَا"
    },
    {
      "kind": "text",
      "ar": "وَارْتُقْ بِہٖ فَتْقَنَا"
    },
    {
      "kind": "text",
      "ar": "وَكَثِّرْ بِہٖ قِلَّتَنَا"
    },
    {
      "kind": "text",
      "ar": "وَٲَعْزِزْ بِہٖ ذِلَّتَنَا"
    },
    {
      "kind": "text",
      "ar": "وَٲَغْنِ بِہٖ عَائِلَنَا"
    },
    {
      "kind": "text",
      "ar": "وَاقْضِ بِہٖ عَنْ مُغْرَمِنَا"
    },
    {
      "kind": "text",
      "ar": "وَاجْبُرْ بِہٖ فَقْرَنَا"
    },
    {
      "kind": "text",
      "ar": "وَسُدَّ بِہٖ خَلَّتَنَا"
    },
    {
      "kind": "text",
      "ar": "وَیَسِّرْ بِہٖ عُسْرَنَا"
    },
    {
      "kind": "text",
      "ar": "وَبَیِّضْ بِہٖ وُجُوْھَنَا"
    },
    {
      "kind": "text",
      "ar": "وَفُكَّ بِہٖ ٲَسْرَنَا"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْجِحْ بِہٖ طَلِبَتَنَا"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْجِزْ بِہٖ مَوَاعِیْدَنَا"
    },
    {
      "kind": "text",
      "ar": "وَاسْتَجِبْ بِہٖ دَعْوَتَنَا"
    },
    {
      "kind": "text",
      "ar": "وَٲَعْطِنَا بِہٖ سُؤْلَنَا"
    },
    {
      "kind": "text",
      "ar": "وَبَلِّغْنَا بِہٖ مِنَ الدُّنْیَا وَالْاٰخِرَۃِ اٰمَالَنَا"
    },
    {
      "kind": "text",
      "ar": "وَٲَعْطِنَا بِہٖ فَوْقَ رَغْبَتِنَا"
    },
    {
      "kind": "text",
      "ar": "یَا خَیْرَ الْمَسْؤُوْلِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَوْسَعَ الْمُعْطِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اشْفِ بِہٖ صُدُوْرَنَا"
    },
    {
      "kind": "text",
      "ar": "وَٲَذْھِبْ بِہٖ غَیْظَ قُلُوْبِنَا"
    },
    {
      "kind": "text",
      "ar": "وَاھْدِنَا بِہٖ لِمَا اخْتُلِفَ فِیْہِ مِنَ الْحَقِّ بِاِذْنِكَ"
    },
    {
      "kind": "text",
      "ar": "اِنَّكَ تَھْدِیْ مَنْ تَشَاءُ اِلٰی صِرَاطٍ مُسْتَقِیْمٍ"
    },
    {
      "kind": "text",
      "ar": "وَانْصُرْنَا بِہٖ عَلٰی عَدُوِّكَ وَعَدُوِّنَا"
    },
    {
      "kind": "text",
      "ar": "اِلٰہَ الْحَقِّ اٰمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنَّا نَشْكُوْ اِلَیْكَ فَقْدَ نَبِیِّنَا صَلَوَاتُكَ عَلَیْہِ وَاٰلِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَغَیْبَۃَ وَلِیِّنَا، وَكَثْرَۃَ عَدُوِّنَا"
    },
    {
      "kind": "text",
      "ar": "وَقِلَّۃَ عَدَدِنَا، وَشِدَّۃَ الْفِتَنِ بِنَا"
    },
    {
      "kind": "text",
      "ar": "وَتَظَاھُرَ الزَّمَانِ عَلَیْنَا"
    },
    {
      "kind": "text",
      "ar": "فَصَلِّ عَلٰی مُحَمَّدٍ وَاٰلِہٖ وَٲَعِنَّا عَلٰی ذٰلِكَ"
    },
    {
      "kind": "text",
      "ar": "بِفَتْحٍ مِنْكَ تُعَجِّلُہٗ، وَبِضُرٍّ تَكْشِفُہٗ"
    },
    {
      "kind": "text",
      "ar": "وَنَصْرٍ تُعِزُّھٗ، وَسُلْطَانِ حَقٍّ تُظْھِرُھٗ"
    },
    {
      "kind": "text",
      "ar": "وَرَحْمَۃٍ مِنْكَ تُجَلِّلُنَاہَا"
    },
    {
      "kind": "text",
      "ar": "وَعَافِیَۃٍ مِنْكَ تُلْبِسُنَاہَا"
    },
    {
      "kind": "text",
      "ar": "بِرَحْمَتِكَ یَا ٲَرْحَمَ الرَّاحِمِیْنَ۔"
    }
  ]
}