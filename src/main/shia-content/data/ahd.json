{
  "id": "ahd",
  "title": "دعاء العَهْد",
  "subtitle": "عن الإمام الصادق عليه السلام",
  "source": "مفاتيح الجنان",
  "fiqh": "shia",
  "slides": [
    {
      "kind": "title",
      "ar": "دعاء العَهْد",
      "subtitle": "عن الإمام الصادق عليه السلام"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ رَبَّ النُّوْرِ الْعَظِیْمِ"
    },
    {
      "kind": "text",
      "ar": "وَرَبَّ الْكُرْسِیِّ الرَّفِیْعِ"
    },
    {
      "kind": "text",
      "ar": "وَرَبَّ الْبَحْرِ الْمَسْجُوْرِ"
    },
    {
      "kind": "text",
      "ar": "وَمُنْزِلَ التَّوْرَاۃِ وَالْاِنْجِیْلِ وَالزَّبُوْرِ"
    },
    {
      "kind": "text",
      "ar": "وَرَبَّ الظِّلِّ وَالْحَرُوْرِ"
    },
    {
      "kind": "text",
      "ar": "وَمُنْزِلَ الْقُرْاٰنِ الْعَظِیْمِ"
    },
    {
      "kind": "text",
      "ar": "وَرَبَّ الْمَلَائِكَۃِ الْمُقَرَّبِیْنَ وَالْاَنْبِیَاءِ وَالْمُرْسَلِیْنَ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنِّیْ ٲَسْٲَلُكَ بِوَجْھِكَ الْكَرِیْمِ"
    },
    {
      "kind": "text",
      "ar": "وَبِنُوْرِ وَجْھِكَ الْمُنِیْرِ وَمُلْكِكَ الْقَدِیْمِ"
    },
    {
      "kind": "text",
      "ar": "یَا حَیُّ یَا قَیُّوْمُ، ٲَسْٲَلُكَ بِاسْمِكَ"
    },
    {
      "kind": "text",
      "ar": "الَّذِیْ ٲَشْرَقَتْ بِہِ السَّمٰوَاتُ وَالْاَرَضُوْنَ"
    },
    {
      "kind": "text",
      "ar": "وَبِاسْمِكَ الَّذِیْ یَصْلَحُ بِہِ الْاَوَّلُوْنَ وَالْاٰخِرُوْنَ"
    },
    {
      "kind": "text",
      "ar": "یَا حَیًّا قَبْلَ كُلِّ حَیٍّ، وَیَا حَیًّا بَعْدَ كُلِّ حَیٍّ"
    },
    {
      "kind": "text",
      "ar": "وَیَا حَیًّا حِیْنَ لَا حَیَّ"
    },
    {
      "kind": "text",
      "ar": "یَا مُحْیِیَ الْمَوْتٰی وَمُمِیْتَ الْاَحْیَاءِ"
    },
    {
      "kind": "text",
      "ar": "یَا حَیُّ لَا اِلٰہَ اِلَّا ٲَنْتَ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ بَلِّغْ مَوْلَانَا الْاِمَامَ الْہَادِیَ الْمَھْدِیَّ"
    },
    {
      "kind": "text",
      "ar": "الْقَائِمَ بِٲَمْرِكَ صَلَوَاتُ ﷲِ عَلَیْہِ وَعَلٰی اٰبَائِہِ الطَّاھِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "عَنْ جَمِیْعِ الْمُؤْمِنِیْنَ وَالْمُؤْمِنَاتِ"
    },
    {
      "kind": "text",
      "ar": "فِیْ مَشَارِقِ الْاَرْضِ وَمَغَارِبِہَا"
    },
    {
      "kind": "text",
      "ar": "سَھْلِہَا وَجَبَلِہَا وَبَرِّہَا وَبَحْرِہَا"
    },
    {
      "kind": "text",
      "ar": "وَعَنِّیْ وَعَنْ وَالِدَیَّ مِنَ الصَّلَوَاتِ"
    },
    {
      "kind": "text",
      "ar": "زِنَۃَ عَرْشِ ﷲِ وَمِدَادَ كَلِمَاتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَمَا ٲَحْصَاھُ عِلْمُہٗ وَٲَحَاطَ بِہٖ كِتَابُہٗ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنِّیْ ٲُجَدِّدُ لَہٗ فِیْ صَبِیْحَۃِ یَوْمِیْ ہٰذَا"
    },
    {
      "kind": "text",
      "ar": "وَمَا عِشْتُ مِنْ ٲَیَّامِیْ"
    },
    {
      "kind": "text",
      "ar": "عَھْدًا وَعَقْدًا وَبَیْعَۃً لَہٗ فِیْ عُنُقِیْ"
    },
    {
      "kind": "text",
      "ar": "لَا ٲَحُوْلُ عَنْہَا وَلَا ٲَزُوْلُ ٲَبَدًا"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اجْعَلْنِیْ مِنْ ٲَنْصَارِھٖ"
    },
    {
      "kind": "text",
      "ar": "وَٲَعْوَانِہٖ وَالذَّابِّیْنَ عَنْہُ"
    },
    {
      "kind": "text",
      "ar": "وَالْمُسَارِعِیْنَ اِلَیْہِ فِیْ قَضَاءِ حَوَائِجِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَالْمُمْتَثِلِیْنَ لِاَوَامِرِھٖ، وَالْمُحَامِیْنَ عَنْہُ"
    },
    {
      "kind": "text",
      "ar": "وَالسَّابِقِیْنَ اِلٰی اِرَادَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَالْمُسْتَشْھَدِیْنَ بَیْنَ یَدَیْہِ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ اِنْ حَالَ بَیْنِیْ وَبَیْنَہُ الْمَوْتُ"
    },
    {
      "kind": "text",
      "ar": "الَّذِیْ جَعَلْتَہٗ عَلٰی عِبَادِكَ حَتْمًا مَقْضِیًّا"
    },
    {
      "kind": "text",
      "ar": "فَٲَخْرِجْنِیْ مِنْ قَبْرِیْ مُؤْتَزِرًا كَفَنِیْ"
    },
    {
      "kind": "text",
      "ar": "شَاھِرًا سَیْفِیْ، مُجَرِّدًا قَنَاتِیْ"
    },
    {
      "kind": "text",
      "ar": "مُلَبِّیًا دَعْوَۃَ الدَّاعِیْ فِی الْحَاضِرِ وَالْبَادِیْ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ ٲَرِنِی الطَّلْعَۃَ الرَّشِیْدَۃَ، وَالْغُرَّۃَ الْحَمِیْدَۃَ"
    },
    {
      "kind": "text",
      "ar": "وَاكْحُلْ نَاظِرِیْ بِنَظْرَۃٍ مِنِّیْ اِلَیْہِ"
    },
    {
      "kind": "text",
      "ar": "وَعَجِّلْ فَرَجَہٗ، وَسَہِّلْ مَخْرَجَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَٲَوْسِعْ مَنْھَجَہٗ، وَاسْلُكْ بِیْ مَحَجَّتَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْفِذْ ٲَمْرَھٗ، وَاشْدُدْ ٲَزْرَھٗ۔"
    },
    {
      "kind": "text",
      "ar": "وَاعْمُرِ اللّٰھُمَّ بِہٖ بِلَادَكَ، وَٲَحْیِ بِہٖ عِبَادَكَ"
    },
    {
      "kind": "text",
      "ar": "فَاِنَّكَ قُلْتَ وَقَوْلُكَ الْحَقُّ"
    },
    {
      "kind": "text",
      "ar": "ظَھَرَ الْفَسَادُ فِی الْبَرِّ وَالْبَحْرِ بِمَا كَسَبَتْ ٲَیْدِی النَّاسِ"
    },
    {
      "kind": "text",
      "ar": "فَٲَظْھِرِ اللّٰھُمَّ لَنَا وَلِیَّكَ وَابْنَ بِنْتِ نَبِیِّكَ"
    },
    {
      "kind": "text",
      "ar": "الْمُسَمّٰی بِاسْمِ رَسُوْلِكَ صَلَّی اللہ عَلَیْہِ وَاٰلِہٖ"
    },
    {
      "kind": "text",
      "ar": "حَتّٰی لَا یَظْفَرَ بِشَیْءٍ مِنَ الْبَاطِلِ اِلَّا مَزَّقَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَیُحِقَّ الْحَقَّ وَیُحَقِّقَہٗ۔"
    },
    {
      "kind": "text",
      "ar": "وَاجْعَلْہُ اللّٰھُمَّ مَفْزَعًا لِمَظْلُوْمِ عِبَادِكَ"
    },
    {
      "kind": "text",
      "ar": "وَنَاصِرًا لِمَنْ لَا یَجِدُ لَہٗ نَاصِرًا غَیْرَكَ"
    },
    {
      "kind": "text",
      "ar": "وَمُجَدِّدًا لِمَا عُطِّلَ مِنْ ٲَحْكَامِ كِتَابِكَ"
    },
    {
      "kind": "text",
      "ar": "وَمُشَیِّدًا لِمَا وَرَدَ مِنْ ٲَعْلَامِ دِیْنِكَ"
    },
    {
      "kind": "text",
      "ar": "وَسُنَنِ نَبِیِّكَ صَلَّی ﷲُ عَلَیْہِ وَاٰلِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَاجْعَلْہُ اللّٰھُمَّ مِمَّنْ حَصَّنْتَہٗ مِنْ بَٲْسِ الْمُعْتَدِیْنَ۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ وَسُرَّ نَبِیَّكَ مُحَمَّدًا صَلَّی ﷲُ عَلَیْہِ وَاٰلِہٖ بِرُؤْیَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَمَنْ تَبِعَہٗ عَلٰی دَعْوَتِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَارْحَمِ اسْتِكَانَتَنَا بَعْدَھٗ۔"
    },
    {
      "kind": "text",
      "ar": "اللّٰھُمَّ اكْشِفْ ہٰذِھِ الْغُمَّۃَ عَنْ ہٰذِھِ الْأُمَّۃِ بِحُضُوْرِھٖ"
    },
    {
      "kind": "text",
      "ar": "وَعَجِّلْ لَنَا ظُھُوْرَھٗ"
    },
    {
      "kind": "text",
      "ar": "اِنَّھُمْ یَرَوْنَہٗ بَعِیْدًا وَنَرَاھُ قَرِیْبًا"
    },
    {
      "kind": "text",
      "ar": "بِرَحْمَتِكَ یَا ٲَرْحَمَ الرَّاحِمِیْنَ۔"
    },
    {
      "kind": "text",
      "ar": "الْعَجَلَ الْعَجَلَ یَامَوْلَایَ یَا صَاحِبَ الزَّمَانِ۔"
    }
  ]
}