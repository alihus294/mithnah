{
  "id": "nudbah",
  "title": "دعاء النُّدبة",
  "subtitle": "في ظهور الإمام الحجّة عجّل الله فرجه الشريف",
  "source": "مفاتيح الجنان",
  "fiqh": "shia",
  "slides": [
    {
      "kind": "title",
      "ar": "دعاء النُّدبة",
      "subtitle": "في ظهور الإمام الحجّة ع"
    },
    {
      "kind": "text",
      "ar": "الْحَمْدُ لِلّٰہِ رَبِّ الْعَالَمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَصَلَّی ﷲُ عَلٰی سَیِّدِنَا مُحَمَّدٍ نَبِیِّہٖ وَاٰلِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَسَلَّمَ تَسْلِیْمًا۔"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ لَكَ الْحَمْدُ"
    },
    {
      "kind": "text",
      "ar": "عَلٰی مَا جَرٰی بِہٖ قَضَاؤُكَ فِیْ ٲَوْلِیَائِكَ"
    },
    {
      "kind": "text",
      "ar": "الَّذِیْنَ اسْتَخْلَصْتَھُمْ لِنَفْسِكَ وَدِیْنِكَ"
    },
    {
      "kind": "text",
      "ar": "اِذِ اخْتَرْتَ لَھُمْ جَزِیْلَ مَا عِنْدَكَ"
    },
    {
      "kind": "text",
      "ar": "مِنَ النَّعِیْمِ الْمُقِیْمِ"
    },
    {
      "kind": "text",
      "ar": "الَّذِیْ لَا زَوَالَ لَہٗ وَلَا اضْمِحْلَالَ"
    },
    {
      "kind": "text",
      "ar": "بَعْدَ ٲَنْ شَرَطْتَ عَلَیْھِمُ الزُّھْدَ"
    },
    {
      "kind": "text",
      "ar": "فِیْ دَرَجَاتِ ہٰذِھِ الدُّنْیَا الدَّنِیَّۃِ"
    },
    {
      "kind": "text",
      "ar": "وَزُخْرُفِہَا وَزِبْرِجِہَا"
    },
    {
      "kind": "text",
      "ar": "فَشَرَطُوْا لَكَ ذٰلِكَ وَعَلِمْتَ مِنْھُمُ الْوَفَاءَ بِہٖ"
    },
    {
      "kind": "text",
      "ar": "فَقَبِلْتَھُمْ وَقَرَّبْتَھُمْ"
    },
    {
      "kind": "text",
      "ar": "وَقَدَّمْتَ لَھُمُ الذِّكْرَ الْعَلِیَّ وَالثَّنَاءَ الْجَلِیَّ"
    },
    {
      "kind": "text",
      "ar": "وَٲَھْبَطْتَ عَلَیْھِمْ مَلَائِكَتَكَ"
    },
    {
      "kind": "text",
      "ar": "وَكَرَّمْتَھُمْ بِوَحْیِكَ، وَرَفَدْتَھُمْ بِعِلْمِكَ"
    },
    {
      "kind": "text",
      "ar": "وَجَعَلْتَھُمُ الذَّرِیْعَۃَ اِلَیْكَ"
    },
    {
      "kind": "text",
      "ar": "وَالْوَسِیْلَۃَ اِلٰی رِضْوَانِكَ"
    },
    {
      "kind": "text",
      "ar": "فَبَعْضٌ ٲَسْكَنْتَہٗ جَنَّتَكَ اِلٰی ٲَنْ ٲَخْرَجْتَہٗ مِنْہَا"
    },
    {
      "kind": "text",
      "ar": "وَبَعْضٌ حَمَلْتَہٗ فِیْ فُلْكِكَ"
    },
    {
      "kind": "text",
      "ar": "وَنَجَّیْتَہٗ وَمَنْ اٰمَنَ مَعَہٗ مِنَ الْھَلَكَۃِ بِرَحْمَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَبَعْضٌ اتَّخَذْتَہٗ لِنَفْسِكَ خَلِیْلًا"
    },
    {
      "kind": "text",
      "ar": "وَسَٲَلَكَ لِسَانَ صِدْقٍ فِی الْاٰخِرِیْنَ"
    },
    {
      "kind": "text",
      "ar": "فَٲَجَبْتَہٗ وَجَعَلْتَ ذٰلِكَ عَلِیًّا"
    },
    {
      "kind": "text",
      "ar": "وَبَعْضٌ كَلَّمْتَہٗ مِنْ شَجَرَۃٍ تَكْلِیْمًا"
    },
    {
      "kind": "text",
      "ar": "وَجَعَلْتَ لَہٗ مِنْ ٲَخِیْہِ رِدْئًا وَوَزِیْرًا"
    },
    {
      "kind": "text",
      "ar": "وَبَعْضٌ ٲَوْلَدْتَہٗ مِنْ غَیْرِ ٲَبٍ"
    },
    {
      "kind": "text",
      "ar": "وَاٰتَیْتَہٗ الْبَیِّنَاتِ وَٲَیَّدْتَہٗ بِرُوْحِ الْقُدُسِ"
    },
    {
      "kind": "text",
      "ar": "وَكُلٌّ شَرَعْتَ لَہٗ شَرِیْعَۃً وَنَھَجْتَ لَہٗ مِنْہَاجًا"
    },
    {
      "kind": "text",
      "ar": "وَتَخَیَّرْتَ لَہٗ ٲَوْصِیَاءَ"
    },
    {
      "kind": "text",
      "ar": "مُسْتَحْفِظًا بَعْدَ مُسْتَحْفِظٍ مِنْ مُدَّۃٍ اِلٰی مُدَّۃٍ"
    },
    {
      "kind": "text",
      "ar": "اِقَامَۃً لِدِیْنِكَ وَحُجَّۃً عَلٰی عِبَادِكَ"
    },
    {
      "kind": "text",
      "ar": "وَلِئَلَّا یَزُوْلَ الْحَقُّ عَنْ مَقَرِّھِ"
    },
    {
      "kind": "text",
      "ar": "وَیَغْلِبَ الْبَاطِلُ عَلٰی ٲَھْلِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَلَا یَقُوْلَ ٲَحَدٌ لَوْ لَا ٲَرْسَلْتَ اِلَیْنَا رَسُوْلًا مُنْذِرًا"
    },
    {
      "kind": "text",
      "ar": "وَٲَقَمْتَ لَنَا عَلَمًا ہَادِیًا"
    },
    {
      "kind": "text",
      "ar": "فَنَتَّبِعَ اٰیَاتِكَ مِنْ قَبْلِ ٲَنْ نَذِلَّ وَنَخْزٰی"
    },
    {
      "kind": "text",
      "ar": "اِلٰی ٲَنِ انْتَھَیْتَ بِالْاَمْرِ اِلٰی حَبِیْبِكَ وَنَجِیْبِكَ"
    },
    {
      "kind": "text",
      "ar": "مُحَمَّدٍ صَلَّی ﷲُ عَلَیْہِ وَاٰلِہٖ"
    },
    {
      "kind": "text",
      "ar": "فَكَانَ كَمَا انْتَجَبْتَہٗ سَیِّدَ مَنْ خَلَقْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَصَفْوَۃَ مَنِ اصْطَفَیْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَٲَفْضَلَ مَنِ اجْتَبَیْتَہٗ وَٲَكْرَمَ مَنِ اعْتَمَدْتَہٗ"
    },
    {
      "kind": "text",
      "ar": "قَدَّمْتَہٗ عَلٰی ٲَنْبِیَائِكَ"
    },
    {
      "kind": "text",
      "ar": "وَبَعَثْتَہٗ اِلَی الثَّقَلَیْنِ مِنْ عِبَادِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَوْطَٲْتَہٗ مَشَارِقَكَ وَمَغَارِبَكَ"
    },
    {
      "kind": "text",
      "ar": "وَسَخَّرْتَ لَہُ الْبُرَاقَ"
    },
    {
      "kind": "text",
      "ar": "وَعَرَجْتَ بِرُوْحِہِ اِلٰی سَمَائِكَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَوْدَعْتَہٗ عِلْمَ مَا كَانَ وَمَا یَكُوْنُ"
    },
    {
      "kind": "text",
      "ar": "اِلَی انْقِضَاءِ خَلْقِكَ"
    },
    {
      "kind": "text",
      "ar": "ثُمَّ نَصَرْتَہٗ بِالرُّعْبِ وَحَفَفْتَہٗ بِجَبْرَائِیْلَ وَمِیْكَائِیْلَ"
    },
    {
      "kind": "text",
      "ar": "وَالْمُسَوِّمِیْنَ مِنْ مَلَائِكَتِكَ"
    },
    {
      "kind": "text",
      "ar": "وَوَعَدْتَہٗ ٲَنْ تُظْھِرَ دِیْنَہٗ عَلَی الدِّیْنِ كُلِّہٖ"
    },
    {
      "kind": "text",
      "ar": "وَلَوْ كَرِھَ الْمُشْرِكُوْنَ"
    },
    {
      "kind": "text",
      "ar": "وَذٰلِكَ بَعْدَ ٲَنْ بَوَّٲْتَہٗ مُبَوَّٲَ صِدْقٍ مِنْ ٲَھْلِہٖ"
    },
    {
      "kind": "text",
      "ar": "وَجَعَلْتَ لَہٗ وَلَھُمْ ٲَوَّلَ بَیْتٍ"
    },
    {
      "kind": "text",
      "ar": "وُضِعَ لِلنَّاسِ لَلَّذِیْ بِبَكَّۃَ مُبَارَكًا وَھُدًى لِلْعَالَمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "فِیْہِ اٰیَاتٌ بَیِّنَاتٌ مَقَامُ اِبْرَاھِیْمَ"
    },
    {
      "kind": "text",
      "ar": "وَمَنْ دَخَلَہٗ كَانَ اٰمِنًا"
    },
    {
      "kind": "text",
      "ar": "وَقُلْتَ اِنَّمَا یُرِیْدُ ﷲُ لِیُذْھِبَ عَنْكُمُ الرِّجْسَ ٲَھْلَ الْبَیْتِ"
    },
    {
      "kind": "text",
      "ar": "وَیُطَہِّرَكُمْ تَطْھِیْرًا"
    },
    {
      "kind": "text",
      "ar": "ثُمَّ جَعَلْتَ ٲَجْرَ مُحَمَّدٍ صَلَوَاتُكَ عَلَیْہِ وَاٰلِہٖ"
    },
    {
      "kind": "text",
      "ar": "مَوَدَّتَھُمْ فِیْ كِتَابِكَ"
    },
    {
      "kind": "text",
      "ar": "فَقُلْتَ قُلْ لَا ٲَسْٲَلُكُمْ عَلَیْہِ ٲَجْرًا اِلَّا الْمَوَدَّ ۃَ فِی الْقُرْبٰی"
    },
    {
      "kind": "text",
      "ar": "وَقُلْتَ مَا سَٲَلْتُكُمْ مِنْ ٲَجْرٍ فَھُوَ لَكُمْ"
    },
    {
      "kind": "text",
      "ar": "وَقُلْتَ مَا ٲَسْٲَلُكُمْ عَلَیْہِ مِنْ ٲَجْرٍ"
    },
    {
      "kind": "text",
      "ar": "اِلَّا مَنْ شَاءَ ٲَنْ یَتَّخِذَ اِلٰی رَبِّہٖ سَبِیْلًا"
    },
    {
      "kind": "text",
      "ar": "فَكَانُوْا ھُمُ السَّبِیْلَ اِلَیْكَ"
    },
    {
      "kind": "text",
      "ar": "وَالْمَسْلَكَ اِلٰی رِضْوَانِكَ"
    },
    {
      "kind": "text",
      "ar": "فَلَمَّا انْقَضَتْ ٲَیَّامُہٗ"
    },
    {
      "kind": "text",
      "ar": "ٲَقَامَ وَلِیَّہُ عَلِیَّ بْنَ ٲَبِیْ طَالِبٍ صَلَوَاتُكَ عَلَیْھِمَا وَاٰلِہِمَا"
    },
    {
      "kind": "text",
      "ar": "ہَادِیًا اِذْ كَانَ ھُوَ الْمُنْذِرَ وَلِكُلِّ قَوْمٍ ہَادٍ"
    },
    {
      "kind": "text",
      "ar": "فَقَالَ وَالْمَلَاُ ٲَمَامَہٗ مَنْ كُنْتُ مَوْلَاھُ فَعَلِیٌّ مَوْلَاھُ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ وَالِ مَنْ وَالَاھُ وَعَادِ مَنْ عَادَاھُ"
    },
    {
      "kind": "text",
      "ar": "وَانْصُرْ مَنْ نَصَرَھٗ وَاخْذُلْ مَنْ خَذَلَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَقَالَ مَنْ كُنْتُ ٲَنَا نَبِیَّہٗ فَعَلِیٌّ ٲَمِیْرُھٗ"
    },
    {
      "kind": "text",
      "ar": "وَقَالَ ٲَنَا وَعَلِیٌّ مِنْ شَجَرَۃٍ وَاحِدَۃٍ"
    },
    {
      "kind": "text",
      "ar": "وَسَائِرُ النَّاسِ مِنْ شَجَرٍ شَتّٰی"
    },
    {
      "kind": "text",
      "ar": "وَٲَحَلَّہٗ مَحَلَّ ھَارُوْنَ مِنْ مُوْسٰی"
    },
    {
      "kind": "text",
      "ar": "فَقَالَ لَہٗ ٲَنْتَ مِنِّیْ بِمَنْزِلَۃِ ہَارُوْنَ مِنْ مُوْسٰی"
    },
    {
      "kind": "text",
      "ar": "اِلَّا ٲَنَّہٗ لَا نَبِیَّ بَعْدِیْ"
    },
    {
      "kind": "text",
      "ar": "وَزَوَّجَہُ ابْنَتَہٗ سَیِّدَۃَ نِسَاءِ الْعَالَمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "وَٲَحَلَّ لَہٗ مِنْ مَسْجِدِھٖ مَا حَلَّ لَہٗ"
    },
    {
      "kind": "text",
      "ar": "وَسَدَّ الْاَبْوَابَ اِلَّا بَابَہٗ"
    },
    {
      "kind": "text",
      "ar": "ثُمَّ ٲَوْدَعَہٗ عِلْمَہٗ وَحِكْمَتَہٗ"
    },
    {
      "kind": "text",
      "ar": "فَقَالَ ٲَنَا مَدِیْنَۃُ الْعِلْمِ وَعَلِیٌّ بَابُہَا"
    },
    {
      "kind": "text",
      "ar": "فَمَنْ ٲَرَادَ الْمَدِیْنَۃَ وَالْحِكْمَۃَ فَلْیَٲْتِہَا مِنْ بَابِہَا"
    },
    {
      "kind": "text",
      "ar": "ثُمَّ قَالَ ٲَنْتَ ٲَخِیْ وَوَصِیِّیْ وَوَارِثِیْ"
    },
    {
      "kind": "text",
      "ar": "لَحْمُكَ مِنْ لَحْمِیْ وَدَمُكَ مِنْ دَمِیْ"
    },
    {
      "kind": "text",
      "ar": "وَسِلْمُكَ سِلْمِیْ وَحَرْبُكَ حَرْبِیْ"
    },
    {
      "kind": "text",
      "ar": "وَالْاِیْمَانُ مُخَالِطٌ لَحْمَكَ وَدَمَكَ"
    },
    {
      "kind": "text",
      "ar": "كَمَا خَالَطَ لَحْمِیْ وَدَمِیْ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْتَ غَدًا عَلَی الْحَوْضِ خَلِیْفَتِیْ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْتَ تَقْضِیْ دَیْنِیْ وَتُنْجِزُ عِدَاتِیْ"
    },
    {
      "kind": "text",
      "ar": "وَشِیْعَتُكَ عَلٰی مَنَابِرَ مِنْ نُوْرٍ مُبْیَضَّۃً وُجُوْھُھُمْ"
    },
    {
      "kind": "text",
      "ar": "حَوْلِیْ فِی الْجَنَّۃِ وَھُمْ جِیْرَانِیْ"
    },
    {
      "kind": "text",
      "ar": "وَلَوْ لَا ٲَنْتَ یَا عَلِیُّ لَمْ یُعْرَفِ الْمُؤْمِنُوْنَ بَعْدِیْ"
    },
    {
      "kind": "text",
      "ar": "وَكَانَ بَعْدَھٗ ھُدًى مِنَ الضَّلَالِ وَنُوْرًا مِنَ الْعَمٰی"
    },
    {
      "kind": "text",
      "ar": "وَحَبْلَ ﷲِ الْمَتِیْنَ وَصِرَاطَہُ الْمُسْتَقِیْمَ"
    },
    {
      "kind": "text",
      "ar": "لَا یُسْبَقُ بِقَرَابَۃٍ فِیْ رَحِمٍ"
