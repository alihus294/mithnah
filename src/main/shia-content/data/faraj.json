{
  "id": "faraj",
  "title": "دعاء الفَرَج",
  "subtitle": "علّمه الإمام الحجّة عجّل الله فرجه الشريف",
  "source": "مفاتيح الجنان",
  "fiqh": "shia",
  "slides": [
    {
      "kind": "title",
      "ar": "دعاء الفَرَج",
      "subtitle": "علّمه الإمام الحجّة ع"
    },
    {
      "kind": "text",
      "ar": "اِلٰھِیْ عَظُمَ الْبَلَاءُ، وَبَرِحَ الْخَفَاءُ"
    },
    {
      "kind": "text",
      "ar": "وَانْكَشَفَ الْغِطَاءُ، وَانْقَطَعَ الرَّجَاءُ"
    },
    {
      "kind": "text",
      "ar": "وَضَاقَتِ الْاَرْضُ وَمُنِعَتِ السَّمَاءُ"
    },
    {
      "kind": "text",
      "ar": "وَٲَنْتَ الْمُسْتَعَانُ، وَاِلَیْكَ الْمُشْتَكٰی"
    },
    {
      "kind": "text",
      "ar": "وَعَلَیْكَ الْمُعَوَّلُ فِی الشِّدَّۃِ وَالرَّخَاءِ"
    },
    {
      "kind": "text",
      "ar": "اَللّٰھُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَاٰلِ مُحَمَّدٍ"
    },
    {
      "kind": "text",
      "ar": "ٲُولِی الْأَمْرِ الَّذِیْنَ فَرَضْتَ عَلَیْنَا طَاعَتَھُمْ"
    },
    {
      "kind": "text",
      "ar": "وَعَرَّفْتَنَا بِذٰلِكَ مَنْزِلَتَھُمْ"
    },
    {
      "kind": "text",
      "ar": "فَفَرِّجْ عَنّا بِحَقِّھِمْ، فَرَجًا عَاجِلًا قَرِیْبًا"
    },
    {
      "kind": "text",
      "ar": "كَلَمْحِ الْبَصَرِ ٲَوْ ھُوَ ٲَقْرَبُ"
    },
    {
      "kind": "text",
      "ar": "یَا مُحَمَّدُ یَا عَلِیُّ یَا عَلِیُّ یَا مُحَمَّدُ"
    },
    {
      "kind": "text",
      "ar": "اِكْفِیَانِیْ فَاِنَّكُمَا كَافِیَانِ"
    },
    {
      "kind": "text",
      "ar": "وَانْصُرَانِیْ فَاِنَّكُمَا نَاصِرَانِ"
    },
    {
      "kind": "text",
      "ar": "یَا مَوْلَانَا یَا صَاحِبَ الزَّمَانِ"
    },
    {
      "kind": "text",
      "ar": "الْغَوْثَ الْغَوْثَ الْغَوْثَ"
    },
    {
      "kind": "text",
      "ar": "ٲَدْرِكْنِیْ ٲَدْرِكْنِیْ ٲَدْرِكْنِیْ"
    },
    {
      "kind": "text",
      "ar": "السَّاعَۃَ السَّاعَۃَ السّاعَۃَ"
    },
    {
      "kind": "text",
      "ar": "الْعَجَلَ الْعَجَلَ الْعَجَلَ"
    },
    {
      "kind": "text",
      "ar": "یَا ٲَرْحَمَ الرَّاحِمِیْنَ"
    },
    {
      "kind": "text",
      "ar": "بِحَقِّ مُحَمَّدٍ وَاٰلِہِ الطَّاھِرِیْنَ"
    }
  ]
}